<!-- DYNAMIC SERVICES FROM DB -->
<section class="section" id="portfolio">
  <div class="section-label fade-in">Book A Service</div>
  <h2 class="section-title fade-in d1">Our <span class="accent">Portfolio</span></h2>

  <div class="services-grid">
    <% if (items && items.length > 0) { %>
      <% items.forEach((item, index) => { %>
        <div class="service-card fade-in">

          <div class="service-num"><%= String(index + 1).padStart(2, '0') %></div>

          <!-- MEDIA -->
          <% if (item.media.type === "image") { %>
            <img src="<%= item.media.url %>"
              style="width:100%; height:180px; object-fit:cover; border-radius:10px; margin-bottom:15px;"
              alt="<%= item.title %>">
          <% } else { %>
            <video src="<%= item.media.url %>" controls
              style="width:100%; height:180px; object-fit:cover; border-radius:10px; margin-bottom:15px;"></video>
          <% } %>

          <div class="service-name"><%= item.title %></div>
          <p class="service-desc"><%= item.subtitle %></p>

          <p style="margin-top:10px; font-weight:600; color:#FF6B00;">
            ₹<%= item.price.toLocaleString('en-IN') %>
          </p>

          <div style="margin-top:20px; display:flex; gap:10px; flex-wrap:wrap;">

            <% if (user) { %>
              <!-- ✅ JS-based Stripe redirect (no form POST) -->
              <button
                class="btn-primary"
                onclick="handlePayment('<%= item._id %>', this)">
                <span>Pay &amp; Book</span>
              </button>
            <% } else { %>
              <a href="/signin" class="btn-primary">
                <span>Login to Book</span>
              </a>
            <% } %>

            <% if (user && user.role === "admin") { %>
              <form action="/portfolio/delete/<%= item._id %>" method="POST"
                onsubmit="return confirm('Delete this service?')">
                <button type="submit" class="btn-dark">Delete</button>
              </form>
            <% } %>

          </div>
        </div>
      <% }) %>
    <% } else { %>
      <div style="grid-column:1/-1; text-align:center; color:#aaa; padding:40px;">
        No services available.
      </div>
    <% } %>
  </div>
</section>

