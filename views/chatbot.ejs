<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>CreativeForge AI — Chat</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=Syne:wght@600;700;800&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}

:root{
  --lime:#C8F135;
  --lime-glow:rgba(200,241,53,0.15);
  --lime-border:rgba(200,241,53,0.18);
  --lime-dim:rgba(200,241,53,0.08);
  --dark:#080b10;
  --dark2:#0a0d14;
  --surface:#0d1117;
  --surface2:#111827;
  --surface3:#141c28;
  --card:#0f1520;
  --card2:#131d2e;
  --fg:#eef2ff;
  --fg2:#8b9ab8;
  --fg3:#3d4f68;
  --nav-h:68px;
  --sb-w:260px;
}

html,body{height:100%}

body{
  background:var(--dark);
  color:var(--fg);
  font-family:'DM Sans',sans-serif;
  overflow-x:hidden;
  min-height:100vh;
}

/* ── AMBIENT ── */
.bg-canvas{
  position:fixed;inset:0;
  pointer-events:none;z-index:0;
  overflow:hidden;
}
.bg-canvas::before{
  content:'';
  position:absolute;
  width:900px;height:900px;
  border-radius:50%;
  background:radial-gradient(circle,rgba(200,241,53,0.045) 0%,transparent 60%);
  top:-300px;right:-200px;
  animation:driftA 20s ease-in-out infinite alternate;
}
.bg-canvas::after{
  content:'';
  position:absolute;
  width:600px;height:600px;
  border-radius:50%;
  background:radial-gradient(circle,rgba(200,241,53,0.025) 0%,transparent 65%);
  bottom:-150px;left:-100px;
  animation:driftB 25s ease-in-out infinite alternate;
}
@keyframes driftA{from{transform:translate(0,0) scale(1)}to{transform:translate(-80px,100px) scale(1.12)}}
@keyframes driftB{from{transform:translate(0,0) scale(1)}to{transform:translate(60px,-70px) scale(1.1)}}

.bg-grid{
  position:fixed;inset:0;
  background-image:
    linear-gradient(rgba(200,241,53,0.016) 1px,transparent 1px),
    linear-gradient(90deg,rgba(200,241,53,0.016) 1px,transparent 1px);
  background-size:56px 56px;
  pointer-events:none;z-index:0;
}

/* ── NAVBAR ── */
nav{
  position:fixed;top:0;left:0;right:0;
  height:var(--nav-h);
  background:rgba(8,11,16,0.82);
  backdrop-filter:blur(18px);
  -webkit-backdrop-filter:blur(18px);
  border-bottom:1px solid rgba(200,241,53,0.08);
  display:flex;align-items:center;
  padding:0 32px;
  gap:12px;
  z-index:100;
}
.nav-logo{
  display:flex;align-items:center;gap:11px;
  text-decoration:none;
}
.nav-logo-orb{
  width:34px;height:34px;border-radius:50%;
  background:conic-gradient(from 0deg,#C8F135,#9ab020,#608010,#C8F135);
  display:flex;align-items:center;justify-content:center;
  position:relative;
  animation:orbHue 12s linear infinite;
}
.nav-logo-orb::after{content:'';position:absolute;inset:2.5px;border-radius:50%;background:var(--dark2)}
.nav-logo-orb span{position:relative;z-index:1;font-size:14px}
@keyframes orbHue{from{filter:hue-rotate(0deg)}to{filter:hue-rotate(35deg)}}

.nav-brand{
  font-family:'Bebas Neue',sans-serif;
  font-size:22px;letter-spacing:3px;
  color:var(--fg);line-height:1;
}
.nav-brand em{color:var(--lime);font-style:normal}

.nav-pill{
  margin-left:auto;
  display:flex;align-items:center;gap:6px;
  padding:6px 14px;
  border:1px solid rgba(200,241,53,0.2);
  border-radius:40px;
  background:var(--lime-dim);
  font-family:'Syne',sans-serif;
  font-size:10px;font-weight:700;
  letter-spacing:2px;text-transform:uppercase;
  color:var(--lime);
}
.pulse{
  width:7px;height:7px;border-radius:50%;
  background:var(--lime);
  box-shadow:0 0 8px rgba(200,241,53,0.7);
  animation:pulse 2s ease-in-out infinite;
}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:0.3;transform:scale(0.85)}}

/* ── PAGE LAYOUT ── */
.page{
  position:relative;z-index:1;
  min-height:100vh;
  padding:calc(var(--nav-h) + 36px) 24px 48px;
  display:grid;
  grid-template-columns:var(--sb-w) 1fr;
  gap:20px;
  max-width:1180px;
  margin:0 auto;
  align-items:start;
}

/* ══ SIDEBAR ══ */
.sidebar{
  display:flex;flex-direction:column;gap:14px;
  position:sticky;top:calc(var(--nav-h) + 36px);
}

.sc{
  background:var(--surface);
  border:1px solid rgba(255,255,255,0.055);
  border-radius:18px;
  padding:22px 18px;
  position:relative;overflow:hidden;
}
.sc::before{
  content:'';position:absolute;top:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,var(--lime),transparent);
  opacity:0.35;
}

/* AI identity card */
.ai-id{
  display:flex;flex-direction:column;align-items:center;
  text-align:center;gap:14px;
}
.ai-orb{
  width:68px;height:68px;border-radius:50%;
  background:conic-gradient(from 180deg,#C8F135,#a0c020,#6a9010,#C8F135);
  display:flex;align-items:center;justify-content:center;
  position:relative;
  animation:orbHue 14s linear infinite;
  flex-shrink:0;
}
.ai-orb::before{content:'';position:absolute;inset:3px;border-radius:50%;background:var(--surface)}
.ai-orb-ring{position:absolute;inset:-9px;border-radius:50%;border:1px solid rgba(200,241,53,0.18);animation:ringPulse 3s ease-in-out infinite}
@keyframes ringPulse{0%,100%{transform:scale(1);opacity:0.4}50%{transform:scale(1.07);opacity:0.08}}
.ai-orb .ai-icon{position:relative;z-index:1;font-size:26px}

.ai-name{
  font-family:'Bebas Neue',sans-serif;
  font-size:20px;letter-spacing:2.5px;
  color:var(--fg);line-height:1;
}
.ai-sub{font-size:11px;color:var(--fg2);letter-spacing:0.5px;line-height:1.6}
.ai-status{
  display:inline-flex;align-items:center;gap:6px;
  font-family:'Syne',sans-serif;font-size:10px;font-weight:700;
  letter-spacing:1.8px;text-transform:uppercase;
  color:#4ade80;margin-top:4px;
}
.status-dot{
  width:7px;height:7px;border-radius:50%;
  background:#4ade80;box-shadow:0 0 8px rgba(74,222,128,0.6);
  animation:pulse 2.2s ease-in-out infinite;
}

/* section label */
.slabel{
  font-family:'Syne',sans-serif;font-size:9.5px;font-weight:800;
  letter-spacing:3.5px;text-transform:uppercase;color:var(--lime);
  display:flex;align-items:center;gap:8px;margin-bottom:11px;
}
.slabel::after{content:'';flex:1;height:1px;background:var(--lime-border)}

/* topic list */
.topic-list{list-style:none;display:flex;flex-direction:column;gap:2px}
.topic-item{
  display:flex;align-items:center;gap:9px;
  padding:8px 11px;border-radius:9px;
  font-size:12.5px;color:var(--fg2);
  cursor:pointer;transition:all 0.18s;
  border:1px solid transparent;
  user-select:none;
}
.topic-item:hover{background:var(--lime-dim);color:var(--fg);border-color:var(--lime-border)}
.topic-item.active{background:var(--lime-dim);color:var(--lime);border-color:var(--lime-border);font-weight:500}
.ti{font-size:15px;width:18px;text-align:center;flex-shrink:0}

/* topic badge */
#topicBadge{
  display:none;align-items:center;gap:7px;
  font-family:'Syne',sans-serif;font-size:10px;font-weight:700;
  letter-spacing:1.5px;text-transform:uppercase;
  color:var(--lime);background:var(--lime-dim);
  border:1px solid var(--lime-border);
  padding:7px 12px;border-radius:8px;
}
#topicBadge.show{display:flex}

.clear-btn{
  width:100%;padding:10px;
  background:transparent;
  border:1px solid rgba(255,80,80,0.18);
  color:rgba(255,100,100,0.5);
  font-family:'Syne',sans-serif;font-size:9.5px;font-weight:700;
  letter-spacing:2px;text-transform:uppercase;
  border-radius:8px;cursor:pointer;
  transition:all 0.2s;
}
.clear-btn:hover{background:rgba(255,80,80,0.07);border-color:rgba(255,80,80,0.4);color:#ff6060}

/* ══ CHAT SHELL ══ */
.chat-shell{
  display:flex;flex-direction:column;
  background:var(--surface);
  border:1px solid rgba(255,255,255,0.055);
  border-radius:22px;overflow:hidden;
  box-shadow:0 0 0 1px rgba(200,241,53,0.03),0 32px 80px rgba(0,0,0,0.55);
  animation:shellIn 0.6s cubic-bezier(.22,1,.36,1) both;
}
@keyframes shellIn{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:translateY(0)}}

/* header */
.chat-hdr{
  padding:18px 26px;
  background:linear-gradient(135deg,#0c1220 0%,#111c2e 100%);
  border-bottom:1px solid rgba(255,255,255,0.05);
  display:flex;align-items:center;justify-content:space-between;gap:14px;
  position:relative;overflow:hidden;
}
.chat-hdr::after{
  content:'';position:absolute;bottom:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent 0%,var(--lime) 50%,transparent 100%);
  opacity:0.28;
}
.hdr-l{display:flex;align-items:center;gap:13px}
.mac-dots{display:flex;gap:5px}
.mac-dot{width:11px;height:11px;border-radius:50%}

.hdr-title{
  font-family:'Syne',sans-serif;font-size:11.5px;font-weight:700;
  letter-spacing:2.5px;text-transform:uppercase;color:var(--fg2);
}
.msg-count{
  font-family:'Syne',sans-serif;font-size:10px;font-weight:700;
  letter-spacing:1.5px;text-transform:uppercase;
  color:var(--fg3);background:rgba(255,255,255,0.04);
  border:1px solid rgba(255,255,255,0.07);
  padding:4px 13px;border-radius:20px;
}

/* messages area */
.msgs{
  height:54vh;max-height:520px;min-height:280px;
  overflow-y:auto;
  padding:26px 26px 14px;
  display:flex;flex-direction:column;gap:18px;
  scroll-behavior:smooth;
}
.msgs::-webkit-scrollbar{width:3px}
.msgs::-webkit-scrollbar-track{background:transparent}
.msgs::-webkit-scrollbar-thumb{background:rgba(200,241,53,0.14);border-radius:3px}

/* empty state */
.empty{
  flex:1;display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  gap:16px;text-align:center;padding:16px 0;
}
.e-gfx{position:relative;width:76px;height:76px}
.e-ring{position:absolute;inset:0;border-radius:50%;border:1px dashed rgba(200,241,53,0.2);animation:spin 20s linear infinite}
.e-ring2{position:absolute;inset:10px;border-radius:50%;border:1px dashed rgba(200,241,53,0.1);animation:spin 14s linear infinite reverse}
.e-core{position:absolute;inset:20px;border-radius:50%;background:rgba(200,241,53,0.06);display:flex;align-items:center;justify-content:center;font-size:20px}
@keyframes spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}

.e-head{font-family:'Syne',sans-serif;font-size:17px;font-weight:700;color:var(--fg)}
.e-sub{font-size:13px;color:var(--fg2);line-height:1.75;max-width:320px}

.chips{
  display:grid;grid-template-columns:1fr 1fr;gap:7px;
  width:100%;max-width:380px;margin-top:2px;
}
.chip{
  font-size:12px;font-weight:500;color:var(--fg2);
  border:1px solid var(--lime-border);padding:9px 13px;
  border-radius:9px;background:rgba(200,241,53,0.03);
  cursor:pointer;transition:all 0.2s;text-align:left;line-height:1.45;
  user-select:none;
}
.chip:hover{background:var(--lime-dim);border-color:rgba(200,241,53,0.32);color:var(--lime);transform:translateY(-2px)}

/* ── MESSAGES ── */
.msg-row{
  display:flex;gap:11px;align-items:flex-end;
  animation:msgIn 0.38s cubic-bezier(.22,1,.36,1) both;
}
@keyframes msgIn{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
.msg-row.user-row{flex-direction:row-reverse}

.av{
  width:32px;height:32px;border-radius:50%;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;font-size:14px;
}
.av.bot{
  background:conic-gradient(from 0deg,#C8F135,#a0c020,#C8F135);
  position:relative;animation:orbHue 14s linear infinite;
}
.av.bot::before{content:'';position:absolute;inset:2px;border-radius:50%;background:var(--card2)}
.av.bot span{position:relative;z-index:1;font-size:14px}
.av.user{background:linear-gradient(135deg,#1a2540,#1e3050);border:1px solid rgba(200,241,53,0.2)}

.bwrap{display:flex;flex-direction:column;max-width:72%;gap:3px}
.user-row .bwrap{align-items:flex-end}

.sender{
  font-family:'Syne',sans-serif;font-size:9px;font-weight:700;
  letter-spacing:1.8px;text-transform:uppercase;padding:0 5px;
}
.sender.bot{color:var(--lime)}.sender.user{color:var(--fg3)}

/* bot bubble */
.bubble.bot-b{
  background:var(--card2);
  border:1px solid var(--lime-border);
  border-radius:17px;border-bottom-left-radius:3px;
  padding:0;overflow:hidden;position:relative;
}
.bubble.bot-b::before{
  content:'';position:absolute;left:0;top:0;bottom:0;width:2.5px;
  background:linear-gradient(to bottom,var(--lime),rgba(200,241,53,0.18));
  border-radius:2px 0 0 2px;
}
.b-inner{
  padding:13px 17px 13px 21px;
  font-size:13.5px;line-height:1.78;color:rgba(238,242,255,0.9);
}
.b-footer{
  padding:6px 17px 9px 21px;
  border-top:1px solid rgba(200,241,53,0.055);
  display:flex;align-items:center;justify-content:space-between;
  background:rgba(200,241,53,0.018);
}
.btime{font-size:10px;color:var(--fg3)}
.btag{
  font-family:'Syne',sans-serif;font-size:9px;font-weight:700;
  letter-spacing:1.5px;text-transform:uppercase;color:rgba(200,241,53,0.32);
}

/* user bubble */
.bubble.user-b{
  background:linear-gradient(135deg,#C8F135 0%,#b2d52e 100%);
  color:#080b10;font-weight:600;font-size:13.5px;line-height:1.65;
  padding:12px 17px;
  border-radius:17px;border-bottom-right-radius:3px;
  box-shadow:0 4px 20px rgba(200,241,53,0.14);
}
.u-foot{display:flex;align-items:center;justify-content:flex-end;gap:4px;margin-top:2px;padding:0 2px}
.u-time{font-size:10px;color:var(--fg3)}
.tick{font-size:11px;color:var(--lime)}

/* point list inside bot */
.b-inner .plist{list-style:none;display:flex;flex-direction:column;gap:7px;margin-top:6px}
.b-inner .pitem{display:flex;gap:9px;align-items:flex-start;font-size:13.5px;color:rgba(238,242,255,0.88);line-height:1.65}
.pdot{width:5px;height:5px;border-radius:50%;background:var(--lime);flex-shrink:0;margin-top:9px;box-shadow:0 0 6px rgba(200,241,53,0.5)}
.pnum{font-family:'Syne',sans-serif;font-size:9px;font-weight:700;color:var(--lime);background:rgba(200,241,53,0.1);border:1px solid rgba(200,241,53,0.2);border-radius:4px;padding:1px 5px;flex-shrink:0;min-width:20px;text-align:center;margin-top:4px}
.b-inner .mh{font-family:'Syne',sans-serif;font-size:11.5px;font-weight:700;color:var(--lime);letter-spacing:0.5px;margin-bottom:6px;display:flex;align-items:center;gap:5px}
.b-inner .mh::before{content:'';width:10px;height:1px;background:var(--lime);flex-shrink:0}

/* typing indicator */
.typing-row{display:flex;gap:11px;align-items:flex-end}
.typing-bub{
  background:var(--card2);border:1px solid var(--lime-border);
  border-radius:17px;border-bottom-left-radius:3px;
  padding:13px 18px;display:flex;align-items:center;gap:5px;position:relative;
}
.typing-bub::before{content:'';position:absolute;left:0;top:0;bottom:0;width:2.5px;background:linear-gradient(to bottom,var(--lime),rgba(200,241,53,0.18));border-radius:2px 0 0 2px}
.dot{width:6px;height:6px;border-radius:50%;background:var(--lime);opacity:0.4;animation:tdot 1.2s ease-in-out infinite}
.dot:nth-child(2){animation-delay:0.2s}.dot:nth-child(3){animation-delay:0.4s}
@keyframes tdot{0%,60%,100%{transform:translateY(0);opacity:0.3}30%{transform:translateY(-6px);opacity:1}}

/* divider */
.div{height:1px;background:rgba(255,255,255,0.05)}

/* input bar */
.ibar{
  padding:15px 18px;background:#09101e;
  display:flex;align-items:center;gap:9px;
}
.iwrap{
  flex:1;display:flex;align-items:center;gap:9px;
  background:var(--surface3);
  border:1px solid rgba(255,255,255,0.06);
  border-radius:13px;padding:3px 5px 3px 16px;
  transition:border-color 0.28s,box-shadow 0.28s;
}
.iwrap:focus-within{border-color:rgba(200,241,53,0.32);box-shadow:0 0 0 4px rgba(200,241,53,0.045)}
.iwrap input{
  flex:1;background:transparent;border:none;outline:none;
  color:var(--fg);font-family:'DM Sans',sans-serif;font-size:13.5px;
  padding:11px 0;
}
.iwrap input::placeholder{color:rgba(60,80,110,0.7)}
.sbtn{
  width:38px;height:38px;border-radius:9px;
  background:var(--lime);border:none;cursor:pointer;
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
  transition:transform 0.2s,box-shadow 0.2s,background 0.2s;
}
.sbtn:hover{transform:translateY(-2px);box-shadow:0 7px 18px rgba(200,241,53,0.25);background:#d8ff42}
.sbtn:active{transform:scale(0.94)}
.sbtn svg{transition:transform 0.2s}.sbtn:hover svg{transform:translateX(1px)}
.ihint{font-size:10px;color:rgba(60,80,110,0.4);letter-spacing:1.5px;text-transform:uppercase;white-space:nowrap;flex-shrink:0}

/* ── RESPONSIVE ── */
@media(max-width:880px){
  .page{grid-template-columns:1fr;padding:calc(var(--nav-h)+18px) 14px 36px}
  .sidebar{position:static;display:none}
  .msgs{height:55vh}
}
@media(max-width:500px){
  .bwrap{max-width:88%}
  .chips{grid-template-columns:1fr}
  .ihint{display:none}
  nav{padding:0 16px}
}
</style>
</head>
<body>

<!-- ambient -->
<div class="bg-canvas"></div>
<div class="bg-grid"></div>

<!-- nav -->
<nav>
  <a href="#" class="nav-logo">
    <div class="nav-logo-orb"><span>⚡</span></div>
    <div class="nav-brand">Creative<em>Forge</em></div>
  </a>
  <div class="nav-pill">
    <div class="pulse"></div>
    AI Assistant
  </div>
</nav>

<!-- page -->
<div class="page">

  <!-- sidebar -->
  <aside class="sidebar">

    <div class="sc">
      <div class="ai-id">
        <div class="ai-orb">
          <div class="ai-orb-ring"></div>
          <span class="ai-icon">⚡</span>
        </div>
        <div>
          <div class="ai-name">CreativeForge AI</div>
          <div class="ai-sub">Your digital growth strategist</div>
          <div class="ai-status">
            <span class="status-dot"></span>Online
          </div>
        </div>
      </div>
    </div>

    <div class="sc">
      <div class="slabel">Topics</div>
      <ul class="topic-list" id="topicList">
        <li class="topic-item" onclick="setTopic(this,'How can I improve my SEO ranking?')"><span class="ti">🔍</span>SEO &amp; Search</li>
        <li class="topic-item" onclick="setTopic(this,'Best strategy for Meta Ads?')"><span class="ti">📢</span>Paid Ads</li>
        <li class="topic-item" onclick="setTopic(this,'How to grow on Instagram organically?')"><span class="ti">📱</span>Social Media</li>
        <li class="topic-item" onclick="setTopic(this,'I need a brand identity for my business')"><span class="ti">🎨</span>Branding</li>
        <li class="topic-item" onclick="setTopic(this,'I need a website for my business')"><span class="ti">💻</span>Web Dev</li>
        <li class="topic-item" onclick="setTopic(this,'How does email marketing work?')"><span class="ti">✉️</span>Email / WhatsApp</li>
      </ul>
    </div>

    <div class="sc" style="padding:16px 18px;display:flex;flex-direction:column;gap:10px">
      <div id="topicBadge">
        <span>🏷</span>
        <span id="topicText">General</span>
      </div>
      <button class="clear-btn" onclick="clearChat()">✕  Clear Conversation</button>
    </div>

  </aside>

  <!-- chat -->
  <div class="chat-shell">

    <div class="chat-hdr">
      <div class="hdr-l">
        <div class="mac-dots">
          <div class="mac-dot" style="background:#ff5f56"></div>
          <div class="mac-dot" style="background:#febc2e"></div>
          <div class="mac-dot" style="background:#28c840"></div>
        </div>
        <div class="hdr-title">Chat Session</div>
      </div>
      <div class="msg-count" id="counter">0 messages</div>
    </div>

    <div class="msgs" id="msgs">
      <div class="empty" id="emptyState">
        <div class="e-gfx">
          <div class="e-ring"></div>
          <div class="e-ring2"></div>
          <div class="e-core">⚡</div>
        </div>
        <div class="e-head">Ask Me Anything</div>
        <div class="e-sub">
          Marketing strategy, SEO tips, social media growth,<br>branding advice — I've got you covered.
        </div>
        <div class="chips">
          <div class="chip" onclick="useChip(this.textContent)">How to improve SEO?</div>
          <div class="chip" onclick="useChip(this.textContent)">Best Meta Ads strategy?</div>
          <div class="chip" onclick="useChip(this.textContent)">Content calendar tips</div>
          <div class="chip" onclick="useChip(this.textContent)">Grow Instagram fast</div>
        </div>
      </div>
    </div>

    <div class="div"></div>

    <div class="ibar">
      <div class="iwrap">
        <input id="chatInput" placeholder="Ask about SEO, Ads, Social Media..." autocomplete="off"/>
      </div>
      <button class="sbtn" onclick="sendMessage()" title="Send">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M1.5 7h11M8 2.5l4.5 4.5L8 11.5" stroke="#080b10" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <span class="ihint">↵ Enter</span>
    </div>

  </div>
</div>

<script>
// ── state ──
const input      = document.getElementById('chatInput');
const msgArea    = document.getElementById('msgs');
const counter    = document.getElementById('counter');
const topicBadge = document.getElementById('topicBadge');
const topicText  = document.getElementById('topicText');

let sessionId = localStorage.getItem('cf_sid');
if (!sessionId) {
  sessionId = 'sess_' + Date.now() + '_' + Math.random().toString(36).slice(2,9);
  localStorage.setItem('cf_sid', sessionId);
}

let msgCount = 0;

function getTime() {
  return new Date().toLocaleTimeString([], { hour:'2-digit', minute:'2-digit' });
}

function removeEmpty() {
  const e = document.getElementById('emptyState');
  if (e) e.remove();
}

function updateCounter() {
  counter.textContent = msgCount + (msgCount === 1 ? ' message' : ' messages');
}

function updateTopic(topic) {
  if (topic && topic !== 'General') {
    topicText.textContent = topic;
    topicBadge.classList.add('show');
  }
}

// ── format bot text into styled HTML ──
function formatBotReply(text) {
  const lines = text.split('\n').filter(l => l.trim());
  let html = '', inList = false, listNum = 0;

  lines.forEach(line => {
    const t = line.trim();
    const numMatch    = t.match(/^(\d+)[.)]\s+(.+)/);
    const bulletMatch = t.match(/^[-*•]\s+(.+)/);
    const headingMatch= t.match(/^\*\*(.*?)\*\*$|^##\s+(.+)/);

    if (headingMatch) {
      if (inList) { html += '</ul>'; inList = false; listNum = 0; }
      html += `<div class="mh">${headingMatch[1] || headingMatch[2]}</div>`;
    } else if (numMatch) {
      if (!inList) { html += '<ul class="plist">'; inList = true; }
      listNum++;
      html += `<li class="pitem">
        <span class="pnum">${listNum}</span>
        <span>${numMatch[2].replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')}</span>
      </li>`;
    } else if (bulletMatch) {
      if (!inList) { html += '<ul class="plist">'; inList = true; }
      html += `<li class="pitem">
        <span class="pdot"></span>
        <span>${bulletMatch[1].replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')}</span>
      </li>`;
    } else {
      if (inList) { html += '</ul>'; inList = false; listNum = 0; }
      html += `<p style="margin-bottom:5px">${t.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')}</p>`;
    }
  });

  if (inList) html += '</ul>';
  return html;
}

// ── append message ──
function appendMessage(text, role) {
  removeEmpty();
  msgCount++;
  updateCounter();

  const isUser = role === 'user';
  const row = document.createElement('div');
  row.className = `msg-row${isUser ? ' user-row' : ''}`;

  if (isUser) {
    row.innerHTML = `
      <div class="av user">👤</div>
      <div class="bwrap">
        <div class="sender user">You</div>
        <div class="bubble user-b">${text}</div>
        <div class="u-foot">
          <span class="u-time">${getTime()}</span>
          <span class="tick">✓✓</span>
        </div>
      </div>`;
  } else {
    row.innerHTML = `
      <div class="av bot"><span>⚡</span></div>
      <div class="bwrap">
        <div class="sender bot">CreativeForge AI</div>
        <div class="bubble bot-b">
          <div class="b-inner">${formatBotReply(text)}</div>
          <div class="b-footer">
            <span class="btime">${getTime()}</span>
            <span class="btag">AI Response</span>
          </div>
        </div>
      </div>`;
  }

  msgArea.appendChild(row);
  msgArea.scrollTop = msgArea.scrollHeight;
}

// ── typing indicator ──
function showTyping() {
  removeEmpty();
  const row = document.createElement('div');
  row.className = 'typing-row';
  row.id = 'typingRow';
  row.innerHTML = `
    <div class="av bot"><span>⚡</span></div>
    <div class="typing-bub">
      <span class="dot"></span>
      <span class="dot"></span>
      <span class="dot"></span>
    </div>`;
  msgArea.appendChild(row);
  msgArea.scrollTop = msgArea.scrollHeight;
}

function removeTyping() {
  const t = document.getElementById('typingRow');
  if (t) t.remove();
}

// ── send to backend ──
async function sendMessage() {
  const text = input.value.trim();
  if (!text) return;

  appendMessage(text, 'user');
  input.value = '';
  showTyping();

  try {
    const res = await fetch('/chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ message: text, sessionId })
    });

    const data = await res.json();
    removeTyping();

    if (data.error) {
      appendMessage('⚠️ ' + data.error, 'bot');
    } else {
      appendMessage(data.reply || 'No response.', 'bot');
      if (data.topic) updateTopic(data.topic);
    }
  } catch {
    removeTyping();
    appendMessage('⚠️ Connection error. Please try again.', 'bot');
  }
}

// ── sidebar topic click ──
function setTopic(el, msg) {
  document.querySelectorAll('.topic-item').forEach(i => i.classList.remove('active'));
  el.classList.add('active');
  input.value = msg;
  sendMessage();
}

// ── clear chat ──
async function clearChat() {
  if (!confirm('Clear this conversation?')) return;
  try {
    await fetch(`/chat/history/${sessionId}`, { method: 'DELETE' });
  } catch {}

  sessionId = 'sess_' + Date.now() + '_' + Math.random().toString(36).slice(2,9);
  localStorage.setItem('cf_sid', sessionId);
  msgCount = 0;
  updateCounter();
  topicBadge.classList.remove('show');
  document.querySelectorAll('.topic-item').forEach(el => el.classList.remove('active'));

  msgArea.innerHTML = `
    <div class="empty" id="emptyState">
      <div class="e-gfx">
        <div class="e-ring"></div>
        <div class="e-ring2"></div>
        <div class="e-core">⚡</div>
      </div>
      <div class="e-head">Ask Me Anything</div>
      <div class="e-sub">
        Marketing strategy, SEO tips, social media growth,<br>branding advice — I've got you covered.
      </div>
      <div class="chips">
        <div class="chip" onclick="useChip(this.textContent)">How to improve SEO?</div>
        <div class="chip" onclick="useChip(this.textContent)">Best Meta Ads strategy?</div>
        <div class="chip" onclick="useChip(this.textContent)">Content calendar tips</div>
        <div class="chip" onclick="useChip(this.textContent)">Grow Instagram fast</div>
      </div>
    </div>`;
}

// ── load history on page load ──
async function loadHistory() {
  try {
    const res  = await fetch(`/chat/history/${sessionId}`);
    const data = await res.json();
    if (data.messages && data.messages.length > 0) {
      data.messages.forEach(m => appendMessage(m.content, m.role));
      if (data.topic) updateTopic(data.topic);
    }
  } catch {}
}

// ── chip click ──
function useChip(text) {
  input.value = text.trim();
  sendMessage();
}

// ── keyboard ──
input.addEventListener('keypress', e => {
  if (e.key === 'Enter') sendMessage();
});

loadHistory();
</script>
</body>
</html>