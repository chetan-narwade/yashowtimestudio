<%- include("partials/head") %>
<%- include("partials/navbar") %>

<style>
  :root {
    --lime:  #FF6B00;
    --dark:  #0C0F14;
    --dark2: #131820;
    --dark3: #1a2030;
    --white: #ffffff;
    --gray:  #8a9bb0;
    --card:  #141b26;
    --nav-h: 72px;
  }

  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Satoshi', sans-serif;
    background: var(--dark);
    color: var(--white);
    overflow-x: hidden;
  }

  /* ── Page wrapper ── */
  .bookings-page {
    min-height: 100vh;
    padding: calc(var(--nav-h) + 60px) 60px 100px;
  }

  /* ── Header ── */
  .section-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--lime);
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .section-label::before {
    content: '';
    width: 28px;
    height: 1px;
    background: var(--lime);
  }

  .page-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(48px, 7vw, 90px);
    line-height: 1;
    margin-bottom: 48px;
  }

  .page-title span { color: var(--lime); }

  /* ── Alert banners ── */
  .alert {
    padding: 14px 22px;
    border-radius: 8px;
    font-size: 14px;
    margin-bottom: 32px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .alert-success {
    background: rgba(50, 200, 100, 0.1);
    border: 1px solid rgba(50, 200, 100, 0.3);
    color: #4cde8a;
  }

  .alert-warning {
    background: rgba(255, 200, 0, 0.1);
    border: 1px solid rgba(255, 200, 0, 0.3);
    color: #ffc844;
  }

  /* ── Bookings grid ── */
  .bookings-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 20px;
  }

  /* ── Booking card ── */
  .booking-card {
    background: var(--card);
    border: 1px solid rgba(255, 107, 0, 0.08);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.3s, transform 0.3s;
  }

  .booking-card:hover {
    border-color: rgba(255, 107, 0, 0.25);
    transform: translateY(-4px);
  }

  /* ── Card media ── */
  .booking-media {
    width: 100%;
    height: 180px;
    object-fit: cover;
    display: block;
    background: var(--dark3);
  }

  .booking-media-placeholder {
    width: 100%;
    height: 180px;
    background: var(--dark3);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 40px;
  }

  /* ── Card body ── */
  .booking-body {
    padding: 22px;
  }

  .booking-service {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    margin-bottom: 6px;
    color: var(--white);
  }

  .booking-subtitle {
    font-size: 13px;
    color: var(--gray);
    margin-bottom: 16px;
    line-height: 1.5;
  }

  /* ── Meta info ── */
  .booking-meta {
    display: flex;
    flex-direction: column;
    gap: 8px;
    border-top: 1px solid rgba(255, 107, 0, 0.08);
    padding-top: 16px;
  }

  .meta-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 13px;
  }

  .meta-label { color: var(--gray); }

  .meta-value { font-weight: 600; color: var(--white); }

  .meta-value.price { color: var(--lime); font-size: 16px; }

  /* ── Status badge ── */
  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 12px;
    border-radius: 40px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .status-paid {
    background: rgba(50, 200, 100, 0.12);
    color: #4cde8a;
    border: 1px solid rgba(50, 200, 100, 0.25);
  }

  .status-pending {
    background: rgba(255, 200, 0, 0.12);
    color: #ffc844;
    border: 1px solid rgba(255, 200, 0, 0.25);
  }

  .status-failed {
    background: rgba(255, 77, 77, 0.12);
    color: #ff6b6b;
    border: 1px solid rgba(255, 77, 77, 0.25);
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: currentColor;
  }

  /* ── Empty state ── */
  .empty-state {
    text-align: center;
    padding: 80px 40px;
    color: var(--gray);
  }

  .empty-icon {
    font-size: 56px;
    margin-bottom: 20px;
    display: block;
  }

  .empty-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 32px;
    color: var(--white);
    margin-bottom: 10px;
  }

  .empty-desc {
    font-size: 14px;
    margin-bottom: 28px;
    line-height: 1.6;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    background: var(--lime);
    color: var(--dark);
    border: none;
    padding: 14px 32px;
    border-radius: 40px;
    cursor: pointer;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.2s;
  }

  .btn-primary:hover { opacity: 0.88; transform: translateY(-2px); }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .bookings-page { padding: calc(var(--nav-h) + 32px) 24px 60px; }
    .bookings-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 480px) {
    .bookings-page { padding: calc(var(--nav-h) + 20px) 16px 48px; }
  }
</style>

<div class="bookings-page">

  <div class="section-label">My Account</div>
  <h1 class="page-title">My <span>Bookings</span></h1>

  <!-- ✅ Success alert -->
  <% if (success) { %>
    <div class="alert alert-success">
      ✅ Payment successful! Your service has been booked.
    </div>
  <% } %>

  <!-- ⚠️ Duplicate alert -->
  <% if (duplicate) { %>
    <div class="alert alert-warning">
      ⚠️ You have already booked this service.
    </div>
  <% } %>

  <!-- ✅ Bookings grid -->
  <% if (bookings && bookings.length > 0) { %>

    <div class="bookings-grid">
      <% bookings.forEach(function(booking) { %>

        <div class="booking-card">

          <!-- Media -->
          <% if (booking.serviceId && booking.serviceId.media) { %>
            <% if (booking.serviceId.media.type === 'image') { %>
              <img
                class="booking-media"
                src="<%= booking.serviceId.media.url %>"
                alt="<%= booking.serviceId.title %>">
            <% } else { %>
              <video
                class="booking-media"
                src="<%= booking.serviceId.media.url %>"
                muted autoplay loop playsinline>
              </video>
            <% } %>
          <% } else { %>
            <div class="booking-media-placeholder">📦</div>
          <% } %>

          <!-- Body -->
          <div class="booking-body">

            <div class="booking-service">
              <%= booking.serviceId ? booking.serviceId.title : "Service Unavailable" %>
            </div>

            <div class="booking-subtitle">
              <%= booking.serviceId ? booking.serviceId.subtitle : "" %>
            </div>

            <div class="booking-meta">

              <!-- Amount -->
              <div class="meta-row">
                <span class="meta-label">Amount Paid</span>
                <span class="meta-value price">
                  ₹<%= booking.amount.toLocaleString('en-IN') %>
                </span>
              </div>

              <!-- Status -->
              <div class="meta-row">
                <span class="meta-label">Status</span>
                <span class="status-badge status-<%= booking.status %>">
                  <span class="status-dot"></span>
                  <%= booking.status %>
                </span>
              </div>

              <!-- Date -->
              <div class="meta-row">
                <span class="meta-label">Booked On</span>
                <span class="meta-value">
                  <%= new Date(booking.createdAt).toLocaleDateString('en-IN', {
                    day:   'numeric',
                    month: 'short',
                    year:  'numeric'
                  }) %>
                </span>
              </div>

              <!-- Payment ID -->
              <% if (booking.paymentIntentId) { %>
                <div class="meta-row">
                  <span class="meta-label">Payment ID</span>
                  <span class="meta-value" style="font-size:11px; color: var(--gray);">
                    <%= booking.paymentIntentId.slice(0, 24) %>...
                  </span>
                </div>
              <% } %>

            </div>
          </div>
        </div>

      <% }); %>
    </div>

  <% } else { %>

    <!-- Empty state -->
    <div class="empty-state">
      <span class="empty-icon">🛒</span>
      <div class="empty-title">No Bookings Yet</div>
      <p class="empty-desc">
        You haven't booked any services yet.<br>
        Explore our portfolio and get started.
      </p>
      <a href="/portfolio" class="btn-primary">Browse Services →</a>
    </div>

  <% } %>

</div>

<%- include("partials/footer") %>
<%- include("partials/scripts") %>