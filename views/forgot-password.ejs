<%- include('partials/navbar') %>
<%- include('partials/head') %>

<style>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: "DM Sans", sans-serif;
    background: #0c0f14;
    color: #fff;
    min-height: 100vh;
  }

  .signup-wrap {
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 100px 20px 60px;
  }

  .signup-box {
    width: 100%;
    max-width: 440px;
    background: #141b26;
    padding: 40px 36px;
    border-radius: 16px;
    border: 1px solid rgba(255, 107, 0, 0.1);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.4);
  }

  /* ── Step indicator ── */
  .signup-steps {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 32px;
  }

  .step {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  .step-dot {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 2px solid #2c3444;
    background: #0c0f14;
    color: #8a9bb0;
    font-size: 12px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    flex-shrink: 0;
  }

  .step.active .step-dot {
    border-color: #FF6B00;
    color: #FF6B00;
    background: rgba(255, 107, 0, 0.1);
    box-shadow: 0 0 0 4px rgba(255, 107, 0, 0.08);
  }

  .step.done .step-dot {
    border-color: #FF6B00;
    background: #FF6B00;
    color: #0c0f14;
    font-size: 15px;
  }

  .step-label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: #444f63;
    white-space: nowrap;
  }

  .step.active .step-label { color: #FF6B00; }
  .step.done  .step-label  { color: #8a9bb0; }

  .step-line {
    flex: 1;
    height: 2px;
    background: #2c3444;
    margin-bottom: 20px;
    min-width: 32px;
    max-width: 60px;
    transition: background 0.4s ease;
  }

  .step-line.done { background: #FF6B00; }

  /* ── Titles ── */
  .signup-title {
    text-align: center;
    font-size: 24px;
    font-weight: 700;
    letter-spacing: -0.3px;
    margin-bottom: 8px;
    color: #fff;
  }

  .signup-subtitle {
    font-size: 13px;
    color: #8a9bb0;
    text-align: center;
    margin-bottom: 28px;
    line-height: 1.7;
  }

  .signup-subtitle strong { color: #FF6B00; font-weight: 600; }

  /* ── Inputs ── */
  .signup-input {
    width: 100%;
    padding: 13px 16px;
    margin-bottom: 14px;
    border-radius: 10px;
    border: 1.5px solid #1e2a3a;
    background: #0c0f14;
    color: #fff;
    font-family: "DM Sans", sans-serif;
    font-size: 14px;
    outline: none;
    transition: border-color 0.25s, box-shadow 0.25s;
    display: block;
  }

  .signup-input:focus {
    border-color: #FF6B00;
    box-shadow: 0 0 0 3px rgba(255, 107, 0, 0.08);
  }

  .signup-input::placeholder { color: rgba(255, 255, 255, 0.18); }

  /* ── OTP single input ── */
  .otp-input {
    width: 100%;
    padding: 13px 16px;
    margin-bottom: 20px;
    border-radius: 10px;
    border: 1.5px solid #1e2a3a;
    background: #0c0f14;
    color: #FF6B00;
    font-family: "DM Sans", sans-serif;
    font-size: 28px;
    font-weight: 800;
    letter-spacing: 10px;
    text-align: center;
    outline: none;
    transition: border-color 0.25s, box-shadow 0.25s;
    display: block;
    -moz-appearance: textfield;
    -webkit-appearance: none;
    appearance: none;
  }

  .otp-input:focus {
    border-color: #FF6B00;
    box-shadow: 0 0 0 3px rgba(255, 107, 0, 0.1);
  }

  .otp-input::placeholder {
    color: rgba(255, 107, 0, 0.2);
    letter-spacing: 6px;
    font-size: 18px;
    font-weight: 400;
  }

  /* ── Password wrap ── */
  .pw-wrap {
    position: relative;
    margin-bottom: 14px;
  }

  .pw-wrap .signup-input {
    margin-bottom: 0;
    padding-right: 48px;
  }

  .pw-toggle {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    cursor: pointer;
    font-size: 17px;
    color: #8a9bb0;
    user-select: none;
    line-height: 1;
    transition: color 0.2s;
  }

  .pw-toggle:hover { color: #FF6B00; }

  /* ── Strength bar ── */
  .strength-wrap { margin-bottom: 16px; }

  .strength-bar {
    height: 4px;
    border-radius: 4px;
    background: #1e2a3a;
    overflow: hidden;
    margin-bottom: 6px;
  }

  .strength-fill {
    height: 100%;
    width: 0;
    border-radius: 4px;
    transition: width 0.35s ease, background 0.35s ease;
  }

  .strength-text {
    font-size: 11px;
    color: #8a9bb0;
    font-weight: 500;
  }

  /* ── Buttons ── */
  .signup-btn {
    width: 100%;
    padding: 14px;
    border: none;
    border-radius: 10px;
    background: #FF6B00;
    color: #0c0f14;
    font-family: "DM Sans", sans-serif;
    font-weight: 700;
    font-size: 14px;
    cursor: pointer;
    margin-top: 6px;
    transition: opacity 0.2s, transform 0.2s, box-shadow 0.2s;
  }

  .signup-btn:hover {
    opacity: 0.92;
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(255, 107, 0, 0.2);
  }

  .signup-btn.ghost {
    background: transparent;
    color: #8a9bb0;
    border: 1.5px solid #1e2a3a;
    margin-top: 10px;
    font-size: 13px;
    box-shadow: none;
  }

  .signup-btn.ghost:hover { background: #1a2030; color: #fff; border-color: #2c3444; }

  /* ── Links ── */
  .signup-links { text-align: center; margin-top: 18px; font-size: 13px; color: #8a9bb0; }
  .signup-links a { color: #FF6B00; text-decoration: none; font-weight: 600; }
  .signup-links a:hover { text-decoration: underline; }

  /* ── Messages ── */
  .msg-error {
    margin-top: 14px;
    padding: 11px 14px;
    border-radius: 8px;
    background: rgba(255, 107, 107, 0.08);
    border: 1px solid rgba(255, 107, 107, 0.25);
    color: #ff6b6b;
    font-size: 13px;
    text-align: center;
    line-height: 1.5;
  }

  .msg-success {
    margin-top: 14px;
    padding: 11px 14px;
    border-radius: 8px;
    background: rgba(255, 107, 0, 0.06);
    border: 1px solid rgba(255, 107, 0, 0.2);
    color: #FF6B00;
    font-size: 13px;
    text-align: center;
    line-height: 1.5;
  }

  /* ── Resend ── */
  .resend-row {
    text-align: center;
    font-size: 13px;
    color: #8a9bb0;
    margin-top: 16px;
  }

  .resend-btn {
    background: none;
    border: none;
    color: #FF6B00;
    cursor: pointer;
    font-size: 13px;
    font-weight: 600;
    padding: 0;
    text-decoration: underline;
    font-family: "DM Sans", sans-serif;
  }

  @media (max-width: 480px) {
    .signup-box { padding: 28px 20px; }
  }
</style>

<%
  /*
   * currentStep logic:
   *   1 — enter email (default)
   *   2 — enter OTP  (showOtp = true)
   *   3 — set new password (otpVerified = true)
   */
  const currentStep =
    typeof step !== 'undefined'                                   ? Number(step)
    : (typeof otpVerified !== 'undefined' && otpVerified)         ? 3
    : (typeof showOtp     !== 'undefined' && showOtp)             ? 2
    : 1;

  const savedEmail = (typeof formData !== 'undefined' && formData) ? (formData.email || '') : '';
%>

<div class="signup-wrap">
  <div class="signup-box">

    <!-- STEP INDICATOR -->
    <div class="signup-steps">
      <div class="step <%= currentStep === 1 ? 'active' : 'done' %>">
        <div class="step-dot"><%= currentStep > 1 ? '✓' : '1' %></div>
        <div class="step-label">Email</div>
      </div>
      <div class="step-line <%= currentStep > 1 ? 'done' : '' %>"></div>
      <div class="step <%= currentStep === 2 ? 'active' : currentStep > 2 ? 'done' : '' %>">
        <div class="step-dot"><%= currentStep > 2 ? '✓' : '2' %></div>
        <div class="step-label">OTP</div>
      </div>
      <div class="step-line <%= currentStep > 2 ? 'done' : '' %>"></div>
      <div class="step <%= currentStep === 3 ? 'active' : '' %>">
        <div class="step-dot">3</div>
        <div class="step-label">Reset</div>
      </div>
    </div>

    <!-- ══ STEP 1 — Email ══ -->
    <% if (currentStep === 1) { %>

      <div class="signup-title">Forgot Password?</div>
      <div class="signup-subtitle">Enter your registered email and we'll send you an OTP to reset your password.</div>

      <form method="POST" action="/send-otp/forgot-password">
        <input class="signup-input" type="email" name="email"
          placeholder="Your email address" required value="<%= savedEmail %>">
        <button type="submit" class="signup-btn">Send OTP &rarr;</button>
      </form>

      <div class="signup-links">Remembered it? <a href="/signin">Back to sign in</a></div>

    <!-- ══ STEP 2 — OTP ══ -->
    <% } else if (currentStep === 2) { %>

      <div class="signup-title">Check Your Email</div>
      <div class="signup-subtitle">
        We sent a 6-digit code to<br>
        <strong><%= savedEmail %></strong>
      </div>

      <form method="POST" action="/verify-otp/forgot-password" id="otpForm">
        <input type="hidden" name="email" value="<%= savedEmail %>">

        <input
          class="otp-input"
          id="otpInput"
          type="text"
          inputmode="numeric"
          name="otp"
          maxlength="6"
          pattern="[0-9]{6}"
          placeholder="_ _ _ _ _ _"
          required
          autocomplete="one-time-code"
          autofocus
        >

        <button type="submit" class="signup-btn">Verify OTP &rarr;</button>
      </form>

      <div class="resend-row">
        Didn't receive it?&nbsp;
        <form method="POST" action="/send-otp/forgot-password" style="display:inline">
          <input type="hidden" name="email" value="<%= savedEmail %>">
          <button type="submit" class="resend-btn">Resend OTP</button>
        </form>
      </div>

      <div class="signup-links" style="margin-top:12px"><a href="/forgot-password">← Use a different email</a></div>

    <!-- ══ STEP 3 — New Password ══ -->
    <% } else if (currentStep === 3) { %>

      <div class="signup-title">Set New Password</div>
      <div class="signup-subtitle">
        OTP verified ✓ &mdash; create a new password for<br>
        <strong><%= savedEmail %></strong>
      </div>

      <form method="POST" action="/forgot-password/reset" id="pwForm">
        <input type="hidden" name="email" value="<%= savedEmail %>">

        <div class="pw-wrap">
          <input class="signup-input" type="password" name="password"
            id="pwNew" placeholder="Create a strong password"
            required autocomplete="new-password">
          <span class="pw-toggle" id="toggleNew">👁</span>
        </div>

        <div class="strength-wrap">
          <div class="strength-bar">
            <div class="strength-fill" id="strengthFill"></div>
          </div>
          <div class="strength-text" id="strengthText">Use 8+ characters, numbers &amp; symbols</div>
        </div>

        <div class="pw-wrap">
          <input class="signup-input" type="password" name="confirmPassword"
            id="pwConfirm" placeholder="Confirm your password"
            required autocomplete="new-password">
          <span class="pw-toggle" id="toggleConfirm">👁</span>
        </div>

        <button type="submit" class="signup-btn">Reset Password &rarr;</button>
      </form>

    <% } %>

    <!-- Messages -->
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="msg-error"><%= error %></div>
    <% } %>
    <% if (typeof success !== 'undefined' && success) { %>
      <div class="msg-success"><%= success %></div>
    <% } %>
    <% if (typeof otpMsg !== 'undefined' && otpMsg) { %>
      <div class="msg-success"><%= otpMsg %></div>
    <% } %>

  </div>
</div>

<script>
/* ══════════════════════════════════════════════
   OTP BOXES — same logic as signup
══════════════════════════════════════════════ */
(function () {
  var input = document.getElementById('otpInput');
  var form  = document.getElementById('otpForm');
  if (!input || !form) return;

  input.addEventListener('input', function () {
    var clean = input.value.replace(/\D/g, '').slice(0, 6);
    input.value = clean;
    if (clean.length === 6) form.submit();
  });

  input.addEventListener('keydown', function (e) {
    var ctrl = ['Backspace','Delete','ArrowLeft','ArrowRight','Tab','Enter'];
    if (ctrl.indexOf(e.key) !== -1) return;
    if (!/^\d$/.test(e.key)) e.preventDefault();
  });
})();

/* ══════════════════════════════════════════════
   PASSWORD TOGGLE
══════════════════════════════════════════════ */
function attachToggle(toggleId, inputId) {
  const btn   = document.getElementById(toggleId);
  const input = document.getElementById(inputId);
  if (!btn || !input) return;
  btn.addEventListener('click', function () {
    const hidden = input.type === 'password';
    input.type      = hidden ? 'text' : 'password';
    btn.textContent = hidden ? '🙈' : '👁';
  });
}
attachToggle('toggleNew',     'pwNew');
attachToggle('toggleConfirm', 'pwConfirm');

/* ══════════════════════════════════════════════
   STRENGTH METER
══════════════════════════════════════════════ */
(function () {
  const input = document.getElementById('pwNew');
  const fill  = document.getElementById('strengthFill');
  const label = document.getElementById('strengthText');
  if (!input) return;

  const levels = [
    { pct: '0%',   bg: '#1e2a3a', text: 'Use 8+ characters, numbers & symbols', color: '#8a9bb0' },
    { pct: '20%',  bg: '#ff4d4d', text: '⚠ Too weak',   color: '#ff4d4d' },
    { pct: '40%',  bg: '#ff9900', text: '● Weak',        color: '#ff9900' },
    { pct: '65%',  bg: '#f0d000', text: '◑ Fair',        color: '#f0d000' },
    { pct: '82%',  bg: '#FF6B00', text: '✔ Good',        color: '#FF6B00' },
    { pct: '100%', bg: '#00e676', text: '✔ Very Strong', color: '#00e676' },
  ];

  input.addEventListener('input', function () {
    const v = input.value;
    let score = 0;
    if (v.length >= 8)           score++;
    if (v.length >= 12)          score++;
    if (/[A-Z]/.test(v))         score++;
    if (/[0-9]/.test(v))         score++;
    if (/[^A-Za-z0-9]/.test(v))  score++;
    const lvl = levels[Math.min(score, levels.length - 1)];
    fill.style.width      = lvl.pct;
    fill.style.background = lvl.bg;
    label.textContent     = lvl.text;
    label.style.color     = lvl.color;
  });
})();

/* ══════════════════════════════════════════════
   CONFIRM PASSWORD MATCH
══════════════════════════════════════════════ */
(function () {
  const form   = document.getElementById('pwForm');
  const pwNew  = document.getElementById('pwNew');
  const pwConf = document.getElementById('pwConfirm');
  if (!form || !pwNew || !pwConf) return;

  pwConf.addEventListener('input', function () {
    if (!pwConf.value) { pwConf.style.borderColor = ''; return; }
    pwConf.style.borderColor = pwConf.value === pwNew.value
      ? 'rgba(255,107,0,0.5)' : '#ff4d4d';
  });

  form.addEventListener('submit', function (e) {
    if (pwNew.value !== pwConf.value) {
      e.preventDefault();
      pwConf.style.borderColor = '#ff4d4d';
      pwConf.focus();
      let err = document.getElementById('pwMismatchMsg');
      if (!err) {
        err = document.createElement('div');
        err.id        = 'pwMismatchMsg';
        err.className = 'msg-error';
        form.after(err);
      }
      err.textContent = 'Passwords do not match.';
    }
  });
})();
</script>

<%- include('partials/footer') %>
<%- include('partials/scripts') %>  
