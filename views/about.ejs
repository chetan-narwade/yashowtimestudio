      <div class="tag">Growth</div>
      <div class="tag">Tech</div>
      <div class="tag">Operations</div>
    </div>

    <div class="hero-cta">
      <a href="/contact" class="btn-primary">Work With Us →</a>
      <a href="/services" class="btn-ghost">Our Services</a>
    </div>
  </div>

</section>

<!-- ═══════════════════════════════════════════
     STATS STRIP
═══════════════════════════════════════════ -->
<div class="stats-strip fade-in d2">
  <div class="stat-box">
    <div class="stat-box-num">4+</div>
    <div class="stat-box-label">Service Pillars</div>
  </div>
