<%- include('partials/head') %>
<%- include('partials/navbar') %>

<style>
  :root {
    --lime:  #FF6B00;
    --dark:  #0C0F14;
    --dark2: #131820;
    --dark3: #1a2030;
    --white: #FFFFFF;
    --gray:  #8a9bb0;
    --card:  #141b26;
    --nav-h: 72px;
  }

  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--dark);
    color: var(--white);
    overflow-x: hidden;
  }

  /* ── Shared ── */
  .section-label {
    font-family: 'Syne', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--lime);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .section-label::before {
    content: '';
    width: 28px;
    height: 1px;
    background: var(--lime);
    flex-shrink: 0;
  }

  /* ── Buttons ── */
  .btn-primary {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: 'Syne', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    background: var(--lime);
    color: var(--dark);
    border: none;
    padding: 15px 36px;
    border-radius: 40px;
    cursor: pointer;
    overflow: hidden;
    text-decoration: none;
    transition: transform 0.2s;
    white-space: nowrap;
  }

  .btn-primary::before {
    content: '';
    position: absolute;
    inset: 0;
    background: #fff;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s cubic-bezier(.77,0,.18,1);
    border-radius: 40px;
  }

  .btn-primary:hover::before { transform: scaleX(1); }
  .btn-primary:hover { transform: translateY(-2px); }
  .btn-primary > * { position: relative; z-index: 1; }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: 'Syne', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--white);
    background: transparent;
    border: 1px solid rgba(255,255,255,0.18);
    padding: 15px 36px;
    border-radius: 40px;
    cursor: pointer;
    text-decoration: none;
    transition: border-color 0.3s, color 0.3s, transform 0.2s;
    white-space: nowrap;
  }

  .btn-ghost:hover {
    border-color: var(--lime);
    color: var(--lime);
    transform: translateY(-2px);
  }

  /* ── Fade-in ── */
  .fade-in {
    opacity: 0;
    transform: translateY(22px);
    animation: fadeInUp 0.9s ease forwards;
  }

  .d1 { animation-delay: 0.15s; }
  .d2 { animation-delay: 0.30s; }
  .d3 { animation-delay: 0.45s; }

  @keyframes fadeInUp {
    to { opacity: 1; transform: translateY(0); }
  }

  /* ═══════════════════════════════════════
     ABOUT HERO
  ═══════════════════════════════════════ */
  .about-hero {
    padding: calc(var(--nav-h) + 60px) 60px 80px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    min-height: 100vh;
  }

  /* ── Visual block ── */
  .about-visual {
    position: relative;
    height: 500px;
  }

  .about-box {
    position: absolute;
    background: var(--card);
    border: 1px solid rgba(255,107,0,0.1);
  }

  .about-box-1 {
    width: 75%;
    height: 75%;
    top: 0;
    right: 0;
  }

  .about-box-2 {
    width: 50%;
    height: 50%;
    bottom: 0;
    left: 0;
    background: var(--lime);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .about-box-2 span {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 60px;
    color: var(--dark);
    line-height: 1;
    text-align: center;
  }

  .about-box-3 {
    width: 35%;
    height: 35%;
    top: 10%;
    left: -5%;
    background: var(--dark3);
    border: 1px solid rgba(255,107,0,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .about-box-3-inner {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    letter-spacing: 2px;
    color: var(--gray);
    text-align: center;
    line-height: 1.3;
  }

  .floating-dot {
    position: absolute;
    border-radius: 50%;
    background: var(--lime);
  }

  .dot-1 {
    width: 60px; height: 60px;
    top: 5%; left: 45%;
    animation: floatDot 4s ease-in-out infinite;
  }

  .dot-2 {
    width: 20px; height: 20px;
    bottom: 25%; right: 5%;
    animation: floatDot 3s ease-in-out infinite 1s;
  }

  @keyframes floatDot {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-15px); }
  }

  /* ── Content block ── */
  .about-content h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(52px, 7vw, 100px);
    line-height: 0.95;
  }

  .about-content h1 .accent { color: var(--lime); }

  .about-content p {
    font-size: 15px;
    line-height: 1.8;
    color: var(--gray);
    margin-top: 20px;
    font-weight: 300;
  }

  .about-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 28px;
  }

  .tag {
    font-family: 'Syne', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    border: 1px solid rgba(255,107,0,0.3);
    color: var(--lime);
    padding: 8px 20px;
    transition: background 0.3s;
  }

  .tag:hover { background: rgba(255,107,0,0.06); }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 36px;
  }

  /* ═══════════════════════════════════════
     PILLARS + MISSION
  ═══════════════════════════════════════ */
  .section {
    padding: 80px 60px 120px;
    position: relative;
  }

  .about-pillars {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2px;
  }

  .pillar {
    background: var(--card);
    padding: 32px;
    border-left: 3px solid var(--lime);
    transition: background 0.3s;
  }

  .pillar:hover { background: var(--dark3); }

  .pillar h3 {
    font-family: 'Syne', sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--lime);
    margin-bottom: 10px;
  }

  .pillar p {
    font-size: 13px;
    line-height: 1.65;
    color: var(--gray);
    margin: 0;
  }

  /* ── Mission ── */
  .mission-block {
    margin-top: 60px;
    border: 1px solid rgba(255,107,0,0.1);
    padding: 60px;
    background: var(--card);
    position: relative;
    overflow: hidden;
  }

  .mission-block::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--lime), transparent);
  }

  .mission-block blockquote {
    font-family: 'Syne', sans-serif;
    font-size: clamp(18px, 2.5vw, 32px);
    font-weight: 600;
    line-height: 1.5;
    max-width: 860px;
    margin-top: 20px;
    color: var(--white);
    border: none;
    padding: 0;
  }

  .mission-block blockquote span { color: var(--lime); }

  /* ── CTA ── */
  .cta-wrap {
    margin-top: 60px;
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    justify-content: center;
  }

  /* ═══════════════════════════════════════
     STATS STRIP
  ═══════════════════════════════════════ */
  .stats-strip {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid rgba(255,107,0,0.08);
    border-bottom: 1px solid rgba(255,107,0,0.08);
  }

  .stat-box {
    padding: 40px 32px;
    text-align: center;
    border-right: 1px solid rgba(255,107,0,0.08);
    transition: background 0.3s;
  }

  .stat-box:last-child { border-right: none; }
  .stat-box:hover { background: rgba(255,107,0,0.03); }

  .stat-box-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 52px;
    color: var(--lime);
    line-height: 1;
  }

  .stat-box-label {
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gray);
    margin-top: 6px;
  }

  /* ═══════════════════════════════════════
     RESPONSIVE
  ═══════════════════════════════════════ */
  @media (max-width: 1024px) {
    .about-hero {
      grid-template-columns: 1fr;
      padding: calc(var(--nav-h) + 40px) 32px 60px;
      min-height: auto;
      gap: 48px;
    }

    /* Put visual below content on tablet */
    .about-visual { order: 2; height: 360px; }
    .about-content { order: 1; }

    .section { padding: 60px 32px 80px; }
    .mission-block { padding: 40px 32px; }
    .stats-strip { grid-template-columns: repeat(2, 1fr); }
    .stat-box:nth-child(2) { border-right: none; }
    .stat-box:nth-child(3) { border-top: 1px solid rgba(255,107,0,0.08); }
    .stat-box:nth-child(4) { border-top: 1px solid rgba(255,107,0,0.08); border-right: none; }
  }

  @media (max-width: 768px) {
    .about-pillars { grid-template-columns: 1fr; }

    .about-box-3 {
      left: 0;
      font-size: 14px;
    }

    .about-box-3-inner { font-size: 14px; }
  }

  @media (max-width: 640px) {
    .about-hero {
      padding: calc(var(--nav-h) + 24px) 20px 48px;
      gap: 40px;
    }

    .about-visual { height: 260px; }

    .about-box-1 { width: 72%; height: 72%; }
    .about-box-2 { width: 52%; height: 48%; }
    .about-box-2 span { font-size: 42px; }
    .about-box-3 { width: 38%; height: 36%; left: 0; top: 8%; }
    .about-box-3-inner { font-size: 12px; letter-spacing: 1px; }
    .dot-1 { width: 36px; height: 36px; }
    .dot-2 { width: 14px; height: 14px; }

    .section { padding: 40px 20px 60px; }
    .mission-block { padding: 28px 20px; }

    .hero-cta { flex-direction: column; }
    .hero-cta .btn-primary,
    .hero-cta .btn-ghost  { width: 100%; justify-content: center; }

    .cta-wrap { flex-direction: column; align-items: center; }
    .cta-wrap .btn-primary,
    .cta-wrap .btn-ghost  { width: 100%; max-width: 340px; justify-content: center; }

    .stats-strip { grid-template-columns: repeat(2, 1fr); }
    .stat-box { padding: 28px 16px; }
    .stat-box-num { font-size: 40px; }
  }

  @media (max-width: 380px) {
    .about-content h1 { font-size: 46px; }
    .stats-strip { grid-template-columns: 1fr 1fr; }
  }
</style>

<!-- ═══════════════════════════════════════════
     ABOUT HERO
═══════════════════════════════════════════ -->
<section class="about-hero">

