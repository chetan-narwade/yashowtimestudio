    <div class="stat-box-num">100%</div>
    <div class="stat-box-label">Transparent Pricing</div>
  </div>
  <div class="stat-box">
    <div class="stat-box-num">∞</div>
    <div class="stat-box-label">Growth Potential</div>
  </div>
</div>

<!-- ═══════════════════════════════════════════
     PILLARS + MISSION
═══════════════════════════════════════════ -->
<section class="section">

  <div class="section-label fade-in">How We Work</div>

  <div class="about-pillars fade-in d1">
    <div class="pillar">
      <h3>Project-Based Services</h3>
      <p>Defined scope. Clear deliverables. Timely execution. Ideal for one-time projects with specific goals.</p>
