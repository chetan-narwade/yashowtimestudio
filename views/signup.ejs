<%- include('partials/navbar') %>
<%- include('partials/head') %>

<style>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: "DM Sans", sans-serif;
    background: #0c0f14;
    color: #fff;
    min-height: 100vh;
  }

  .signup-wrap {
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 100px 20px 60px;
  }

  .signup-box {
    width: 100%;
    max-width: 440px;
    background: #141b26;
    padding: 40px 36px;
    border-radius: 16px;
    border: 1px solid rgba(255, 107, 0, 0.1);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.4);
  }

  /* ── Step indicator ── */
  .signup-steps {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 32px;
  }

  .step {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  .step-dot {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 2px solid #2c3444;
    background: #0c0f14;
    color: #8a9bb0;
    font-size: 12px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    flex-shrink: 0;
  }

  .step.active .step-dot {
    border-color: #FF6B00;
    color: #FF6B00;
    background: rgba(255, 107, 0, 0.1);
    box-shadow: 0 0 0 4px rgba(255, 107, 0, 0.08);
  }

  .step.done .step-dot {
    border-color: #FF6B00;
    background: #FF6B00;
    color: #0c0f14;
    font-size: 15px;
  }

  .step-label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: #444f63;
    white-space: nowrap;
  }

  .step.active .step-label { color: #FF6B00; }
  .step.done  .step-label  { color: #8a9bb0; }

  .step-line {
    flex: 1;
    height: 2px;
    background: #2c3444;
    margin-bottom: 20px;
    min-width: 32px;
    max-width: 60px;
    transition: background 0.4s ease;
  }

  .step-line.done { background: #FF6B00; }

  /* ── Titles ── */
  .signup-title {
    text-align: center;
    font-size: 24px;
    font-weight: 700;
    letter-spacing: -0.3px;
    margin-bottom: 8px;
    color: #fff;
  }

  .signup-subtitle {
    font-size: 13px;
    color: #8a9bb0;
    text-align: center;
    margin-bottom: 28px;
    line-height: 1.7;
  }

  .signup-subtitle strong { color: #FF6B00; font-weight: 600; }

  /* ── Inputs ── */
  .signup-input {
    width: 100%;
    padding: 13px 16px;
    margin-bottom: 14px;
    border-radius: 10px;
    border: 1.5px solid #1e2a3a;
    background: #0c0f14;
    color: #fff;
    font-family: "DM Sans", sans-serif;
    font-size: 14px;
    outline: none;
    transition: border-color 0.25s, box-shadow 0.25s;
    display: block;
  }

  .signup-input:focus {
    border-color: #FF6B00;
    box-shadow: 0 0 0 3px rgba(255, 107, 0, 0.08);
  }

  .signup-input::placeholder { color: rgba(255, 255, 255, 0.18); }

  /* ── OTP single input ── */
  .otp-input {
    width: 100%;
    padding: 13px 16px;
    margin-bottom: 20px;
    border-radius: 10px;
    border: 1.5px solid #1e2a3a;
    background: #0c0f14;
    color: #FF6B00;
    font-family: "DM Sans", sans-serif;
    font-size: 28px;
    font-weight: 800;
    letter-spacing: 10px;
    text-align: center;
    outline: none;
    transition: border-color 0.25s, box-shadow 0.25s;
    display: block;
    -moz-appearance: textfield;
    -webkit-appearance: none;
    appearance: none;
  }

  .otp-input:focus {
    border-color: #FF6B00;
    box-shadow: 0 0 0 3px rgba(255, 107, 0, 0.1);
  }

  .otp-input::placeholder {
    color: rgba(255, 107, 0, 0.2);
    letter-spacing: 6px;
    font-size: 18px;
    font-weight: 400;
  }

  /* ── Password wrap ── */
  .pw-wrap {
    position: relative;
    margin-bottom: 14px;
  }

  .pw-wrap .signup-input {
    margin-bottom: 0;
    padding-right: 48px;
  }

  .pw-toggle {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    cursor: pointer;
    font-size: 17px;
    color: #8a9bb0;
    user-select: none;
    line-height: 1;
    transition: color 0.2s;
  }

  .pw-toggle:hover { color: #FF6B00; }

  /* ── Strength bar ── */
  .strength-wrap { margin-bottom: 16px; }

  .strength-bar {
    height: 4px;
    border-radius: 4px;
    background: #1e2a3a;
    overflow: hidden;
    margin-bottom: 6px;
  }

  .strength-fill {
    height: 100%;
    width: 0;
    border-radius: 4px;
    transition: width 0.35s ease, background 0.35s ease;
  }

  .strength-text {
    font-size: 11px;
    color: #8a9bb0;
    font-weight: 500;
  }

  /* ── Buttons ── */
  .signup-btn {
    width: 100%;
    padding: 14px;
    border: none;
    border-radius: 10px;
    background: #FF6B00;
    color: #0c0f14;
    font-family: "DM Sans", sans-serif;
    font-weight: 700;
    font-size: 14px;
    cursor: pointer;
    margin-top: 6px;
    transition: opacity 0.2s, transform 0.2s, box-shadow 0.2s;
  }

  .signup-btn:hover {
    opacity: 0.92;
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(255, 107, 0, 0.2);
  }

  .signup-btn.ghost {
    background: transparent;
    color: #8a9bb0;
    border: 1.5px solid #1e2a3a;
    margin-top: 10px;
    font-size: 13px;
    box-shadow: none;
  }

  .signup-btn.ghost:hover { background: #1a2030; color: #fff; border-color: #2c3444; }

  /* ── Divider ── */
  .or-divider {
    display: flex;
    align-items: center;
    gap: 14px;
    margin: 20px 0;
    font-size: 12px;
    color: #2c3444;
  }

  .or-divider::before,
  .or-divider::after { content: ''; flex: 1; height: 1px; background: #1e2a3a; }

  /* ── Google ── */
  .signup-google {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 13px;
    border-radius: 10px;
    border: 1.5px solid #1e2a3a;
    text-decoration: none;
    color: #fff;
    font-size: 14px;
    font-weight: 500;
    transition: background 0.2s, border-color 0.2s;
  }

  .signup-google:hover { background: #1a2030; border-color: #2c3444; }
  .google-icon { width: 20px; height: 20px; background: #fff; border-radius: 50%; padding: 2px; flex-shrink: 0; }

  /* ── Links ── */
  .signup-links { text-align: center; margin-top: 18px; font-size: 13px; color: #8a9bb0; }
  .signup-links a { color: #FF6B00; text-decoration: none; font-weight: 600; }
  .signup-links a:hover { text-decoration: underline; }

  /* ── Messages ── */
  .msg-error {
    margin-top: 14px;
    padding: 11px 14px;
    border-radius: 8px;
    background: rgba(255, 107, 107, 0.08);
    border: 1px solid rgba(255, 107, 107, 0.25);
    color: #ff6b6b;
    font-size: 13px;
    text-align: center;
    line-height: 1.5;
  }

  .msg-success {
    margin-top: 14px;
    padding: 11px 14px;
    border-radius: 8px;
    background: rgba(255, 107, 0, 0.06);
    border: 1px solid rgba(255, 107, 0, 0.2);
    color: #FF6B00;
    font-size: 13px;
    text-align: center;
    line-height: 1.5;
  }

  /* ── Resend ── */
  .resend-row {
    text-align: center;
    font-size: 13px;
    color: #8a9bb0;
    margin-top: 16px;
  }

  .resend-btn {
    background: none;
    border: none;
    color: #FF6B00;
    cursor: pointer;
    font-size: 13px;
    font-weight: 600;
    padding: 0;
    text-decoration: underline;
    font-family: "DM Sans", sans-serif;
  }

  @media (max-width: 480px) {
    .signup-wrap { padding: 80px 16px 48px; }
    .signup-box  { padding: 28px 20px; }
    /* FIX: prevents iOS auto-zoom on input focus */
    .signup-input { font-size: 16px; }
  }

  @media (max-width: 380px) {
    .signup-box { padding: 24px 16px; }
  }
</style>

<%
  const currentStep =
    typeof step !== 'undefined'                             ? Number(step)
    : (typeof otpVerified !== 'undefined' && otpVerified)   ? 3
    : (typeof showOtp     !== 'undefined' && showOtp)       ? 2
    : 1;

  const savedName  = (typeof formData !== 'undefined' && formData) ? (formData.name  || '') : '';
  const savedLogin = (typeof formData !== 'undefined' && formData) ? (formData.login || '') : '';
%>

<div class="signup-wrap">
  <div class="signup-box">

    <!-- STEP INDICATOR -->
    <div class="signup-steps">
      <div class="step <%= currentStep === 1 ? 'active' : 'done' %>">
        <div class="step-dot"><%= currentStep > 1 ? '✓' : '1' %></div>
        <div class="step-label">Details</div>
      </div>
      <div class="step-line <%= currentStep > 1 ? 'done' : '' %>"></div>
      <div class="step <%= currentStep === 2 ? 'active' : currentStep > 2 ? 'done' : '' %>">
        <div class="step-dot"><%= currentStep > 2 ? '✓' : '2' %></div>
        <div class="step-label">OTP</div>
      </div>
      <div class="step-line <%= currentStep > 2 ? 'done' : '' %>"></div>
      <div class="step <%= currentStep === 3 ? 'active' : '' %>">
        <div class="step-dot">3</div>
        <div class="step-label">Password</div>
      </div>
    </div>

    <!-- ══ STEP 1 ══ -->
    <% if (currentStep === 1) { %>

      <div class="signup-title">Create Account</div>
      <div class="signup-subtitle">Enter your details to get started</div>

      <form method="POST" action="/send-otp">
        <input class="signup-input" type="text" name="name"
          placeholder="Full name" required value="<%= savedName %>" autocomplete="name">
        <input class="signup-input" type="text" name="login"
          placeholder="Email or mobile number" required value="<%= savedLogin %>" autocomplete="email">
        <button type="submit" class="signup-btn">Send OTP &rarr;</button>
      </form>

      <div class="or-divider">or</div>

      <a class="signup-google" href="/auth/google">
        <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg"
             class="google-icon" alt="Google">
        Continue with Google
      </a>

      <div class="signup-links">Already have an account? <a href="/signin">Sign in</a></div>

    <!-- ══ STEP 2 — OTP ══ -->
    <% } else if (currentStep === 2) { %>

      <div class="signup-title">Verify OTP</div>
      <div class="signup-subtitle">
        We sent a 6-digit code to<br>
        <strong><%= savedLogin %></strong>
      </div>

      <form method="POST" action="/verify-otp" id="otpForm">
        <input type="hidden" name="name"  value="<%= savedName %>">
        <input type="hidden" name="login" value="<%= savedLogin %>">

        <input
          class="otp-input"
          id="otpInput"
          type="text"
          inputmode="numeric"
          name="otp"
          maxlength="6"
          pattern="[0-9]{6}"
          placeholder="_ _ _ _ _ _"
          required
          autocomplete="one-time-code"
          autofocus
        >

        <button type="submit" class="signup-btn" id="verifyBtn">Verify OTP &rarr;</button>
      </form>

      <div class="resend-row">
        Didn't receive it?&nbsp;
        <form method="POST" action="/send-otp" style="display:inline">
          <input type="hidden" name="name"  value="<%= savedName %>">
          <input type="hidden" name="login" value="<%= savedLogin %>">
          <button type="submit" class="resend-btn">Resend OTP</button>
        </form>
      </div>

    <!-- ══ STEP 3 — Password ══ -->
    <% } else if (currentStep === 3) { %>

      <div class="signup-title">Set Your Password</div>
      <div class="signup-subtitle">
        OTP verified ✓ &mdash; now create a password for<br>
        <strong><%= savedLogin %></strong>
      </div>

      <form method="POST" action="/signup" id="pwForm">
        <input type="hidden" name="name"  value="<%= savedName %>">
        <input type="hidden" name="login" value="<%= savedLogin %>">

        <div class="pw-wrap">
          <input class="signup-input" type="password" name="password"
            id="pwNew" placeholder="Create a strong password"
            required autocomplete="new-password">
          <span class="pw-toggle" id="toggleNew">👁</span>
        </div>

        <div class="strength-wrap">
          <div class="strength-bar">
            <div class="strength-fill" id="strengthFill"></div>
          </div>
          <div class="strength-text" id="strengthText">Use 8+ characters, numbers &amp; symbols</div>
        </div>

        <div class="pw-wrap">
          <input class="signup-input" type="password" name="confirmPassword"
            id="pwConfirm" placeholder="Confirm your password"
            required autocomplete="new-password">
          <span class="pw-toggle" id="toggleConfirm">👁</span>
        </div>

        <button type="submit" class="signup-btn">Create Account &rarr;</button>
      </form>

    <% } %>

    <!-- Messages -->
    <% if (typeof signupError !== 'undefined' && signupError) { %>
      <div class="msg-error"><%= signupError %></div>
    <% } %>
    <% if (typeof otpMsg !== 'undefined' && otpMsg) { %>
      <div class="msg-success"><%= otpMsg %></div>
    <% } %>

  </div>
</div>

<script>
/* ══════════════════════════════════════════════════════════════
   OTP AUTO-ADVANCE  — fixed with requestAnimationFrame
   ✔ Desktop keyboard
   ✔ Android soft keyboard
   ✔ iOS keyboard
   ✔ SMS autofill (autocomplete="one-time-code")
   ✔ Clipboard paste
   ✔ Backspace / Delete / Arrow keys
══════════════════════════════════════════════════════════════ */
(function () {
  var input = document.getElementById('otpInput');
  var form  = document.getElementById('otpForm');
  if (!input || !form) return;

  /* Strip non-digits, cap at 6, auto-submit on completion */
  input.addEventListener('input', function () {
    var clean = input.value.replace(/\D/g, '').slice(0, 6);
    input.value = clean;
    if (clean.length === 6) form.submit();
  });

  /* Block non-digit keypresses (allow control keys) */
  input.addEventListener('keydown', function (e) {
    var ctrl = ['Backspace','Delete','ArrowLeft','ArrowRight','Tab','Enter'];
    if (ctrl.indexOf(e.key) !== -1) return;
    if (!/^\d$/.test(e.key)) e.preventDefault();
  });
})();

/* ══════════════════════════════════════════════
   PASSWORD TOGGLE
══════════════════════════════════════════════ */
function attachToggle(toggleId, inputId) {
  var btn   = document.getElementById(toggleId);
  var input = document.getElementById(inputId);
  if (!btn || !input) return;
  btn.addEventListener('click', function () {
    var hidden = input.type === 'password';
    input.type      = hidden ? 'text' : 'password';
    btn.textContent = hidden ? '🙈' : '👁';
  });
}
attachToggle('toggleNew',     'pwNew');
attachToggle('toggleConfirm', 'pwConfirm');

/* ══════════════════════════════════════════════
   STRENGTH METER
══════════════════════════════════════════════ */
(function () {
  var input = document.getElementById('pwNew');
  var fill  = document.getElementById('strengthFill');
  var label = document.getElementById('strengthText');
  if (!input) return;

  var levels = [
    { pct: '0%',   bg: '#1e2a3a', text: 'Use 8+ characters, numbers & symbols', color: '#8a9bb0' },
    { pct: '20%',  bg: '#ff4d4d', text: '⚠ Too weak',    color: '#ff4d4d' },
    { pct: '40%',  bg: '#ff9900', text: '● Weak',         color: '#ff9900' },
    { pct: '65%',  bg: '#f0d000', text: '◑ Fair',         color: '#f0d000' },
    { pct: '82%',  bg: '#FF6B00', text: '✔ Good',         color: '#FF6B00' },
    { pct: '100%', bg: '#00e676', text: '✔ Very Strong',  color: '#00e676' },
  ];

  input.addEventListener('input', function () {
    var v = input.value, score = 0;
    if (v.length >= 8)           score++;
    if (v.length >= 12)          score++;
    if (/[A-Z]/.test(v))         score++;
    if (/[0-9]/.test(v))         score++;
    if (/[^A-Za-z0-9]/.test(v))  score++;
    var lvl = levels[Math.min(score, levels.length - 1)];
    fill.style.width      = lvl.pct;
    fill.style.background = lvl.bg;
    label.textContent     = lvl.text;
    label.style.color     = lvl.color;
  });
})();

/* ══════════════════════════════════════════════
   CONFIRM PASSWORD MATCH
══════════════════════════════════════════════ */
(function () {
  var form   = document.getElementById('pwForm');
  var pwNew  = document.getElementById('pwNew');
  var pwConf = document.getElementById('pwConfirm');
  if (!form || !pwNew || !pwConf) return;

  pwConf.addEventListener('input', function () {
    if (!pwConf.value) { pwConf.style.borderColor = ''; return; }
    pwConf.style.borderColor = pwConf.value === pwNew.value
      ? 'rgba(255,107,0,0.5)' : '#ff4d4d';
  });

  form.addEventListener('submit', function (e) {
    if (pwNew.value !== pwConf.value) {
      e.preventDefault();
      pwConf.style.borderColor = '#ff4d4d';
      pwConf.focus();
      var err = document.getElementById('pwMismatchMsg');
      if (!err) {
        err = document.createElement('div');
        err.id        = 'pwMismatchMsg';
        err.className = 'msg-error';
        form.after(err);
      }
      err.textContent = 'Passwords do not match.';
    }
  });
})();
</script>

<%- include('partials/footer') %>
<%- include('partials/scripts') %>  
