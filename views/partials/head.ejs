<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CreativeForge — Private Growth Studio</title>

  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    /* ── FORCE HIDE DEFAULT CURSOR ── */
    html, body, *, *::before, *::after,
    a, a:hover, a:focus, a:active,
    button, button:hover,
    input, textarea, select,
    label, [role="button"],
    .btn, .btn:hover,
    .nav-link, .dropdown-item,
    [class*="btn"],
    .ynav-btn, .ynav-hamburger,
    .ynav-menu a, .ynav-drawer-nav a {
      cursor: none !important;
    }

    /* ── CURSOR DOT ── */
    .cursor {
      width: 12px;
      height: 12px;
      background: var(--lime, #FF6B00);
      border-radius: 50%;
      position: fixed;
      top: -100px;
      left: -100px;
      pointer-events: none;
      z-index: 999999;
      transform: translate(-50%, -50%);
      transition: transform 0.1s ease;
      mix-blend-mode: difference;
      will-change: left, top;
    }

    /* ── CURSOR RING ── */
    .cursor-follow {
      width: 36px;
      height: 36px;
      border: 1.5px solid var(--lime, #FF6B00);
      border-radius: 50%;
      position: fixed;
      top: -100px;
      left: -100px;
      pointer-events: none;
      z-index: 999998;
      transform: translate(-50%, -50%);
      transition: transform 0.15s ease, opacity 0.15s ease;
      opacity: 0.5;
      will-change: left, top;
    }

    /* ── HOVER STATES ── */
    .cursor.hover        { transform: translate(-50%, -50%) scale(2.5); }
    .cursor-follow.hover { transform: translate(-50%, -50%) scale(1.5); opacity: 0.15; }
  </style>

</head>

<body>

  <!-- Custom Cursor Elements -->
  <div class="cursor" id="cursor"></div>
  <div class="cursor-follow" id="cursorFollow"></div>
