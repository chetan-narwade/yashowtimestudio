<%- include('head') %>
<style>
  :root {
    --lime: #FF6B00;
    --dark: #0C0F14;
    --dark3: #1a2030;
    --white: #FFFFFF;
    --gray: #8a9bb0;
    --card: #141b26;
    --nav-h: 64px;
  }

  .ynav-wrap {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: var(--nav-h);
    z-index: 99999;
    padding: 0 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(20, 27, 36, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255, 107, 0, 0.08);
    transition: background 0.4s, border-color 0.4s;
  }

  .ynav-wrap.scrolled {
    background: rgba(20, 27, 36, 0.97);
    border-color: rgba(255, 107, 0, 0.14);
  }

  .ynav-brand {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    flex-shrink: 0;
    transition: opacity 0.2s;
    z-index: 1;
  }

  .ynav-brand:hover { opacity: 0.85; }

  .ynav-brand img {
    height: 52px;
    width: auto;
    display: block;
    object-fit: contain;
  }

  .ynav-brand-text {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 2px;
    color: var(--white);
    display: block;
  }

  .ynav-brand-text span { color: var(--lime); }

  .ynav-menu {
    display: flex;
    gap: 32px;
    list-style: none;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  .ynav-menu a {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--gray);
    text-decoration: none;
    position: relative;
    transition: color 0.3s;
    white-space: nowrap;
  }

  .ynav-menu a::after {
    content: '';
    position: absolute;
    bottom: -4px; left: 0;
    width: 0; height: 1px;
    background: var(--lime);
    transition: width 0.3s ease;
  }

  .ynav-menu a:hover,
  .ynav-menu a.active { color: var(--white); }

  .ynav-menu a:hover::after,
  .ynav-menu a.active::after { width: 100%; }

  .ynav-actions {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
    z-index: 1;
  }

  .ynav-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 9px 20px;
    border: none;
    cursor: pointer;
    text-decoration: none;
    border-radius: 40px;
    transition: background 0.3s, color 0.3s, transform 0.2s, border-color 0.3s;
    white-space: nowrap;
  }

  .ynav-btn--primary { background: var(--lime); color: var(--dark); }
  .ynav-btn--primary:hover { background: var(--white); color: var(--dark); transform: translateY(-1px); }

  .ynav-btn--ghost {
    background: transparent;
    color: var(--lime);
    border: 1px solid rgba(255, 107, 0, 0.35);
  }

  .ynav-btn--ghost:hover { background: var(--lime); color: var(--dark); transform: translateY(-1px); }

  .ynav-btn--logout {
    background: transparent;
    color: var(--gray);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .ynav-btn--logout:hover {
    background: #ff4d4d;
    color: var(--white);
    border-color: #ff4d4d;
    transform: translateY(-1px);
  }

  /* ✅ My Bookings button */
  .ynav-btn--bookings {
    background: transparent;
    color: var(--white);
    border: 1px solid rgba(255, 107, 0, 0.25);
  }

  .ynav-btn--bookings:hover {
    border-color: var(--lime);
    color: var(--lime);
    transform: translateY(-1px);
  }

  /* ═══════════════════════════════════════
     HAMBURGER
  ═══════════════════════════════════════ */
  .ynav-hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px; height: 40px;
    cursor: pointer;
    background: none;
    border: none;
    padding: 4px;
    border-radius: 8px;
    transition: background 0.2s;
    z-index: 1;
    -webkit-tap-highlight-color: transparent;
  }

  .ynav-hamburger span {
    display: block;
    width: 22px; height: 2px;
    background: var(--white);
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease, width 0.3s ease;
    transform-origin: center;
  }

  .ynav-hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .ynav-hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .ynav-hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ═══════════════════════════════════════
     MOBILE DRAWER
  ═══════════════════════════════════════ */
  .ynav-drawer {
    position: fixed;
    top: var(--nav-h);
    left: 0; right: 0;
    background: rgba(20, 27, 36, 0.98);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border-bottom: 1px solid rgba(255, 107, 0, 0.1);
    padding: 0 24px;
    z-index: 99998;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s cubic-bezier(0.4,0,0.2,1), padding 0.3s ease;
  }

  .ynav-drawer.open { max-height: 700px; padding: 16px 24px 28px; }

  .ynav-drawer-nav { display: flex; flex-direction: column; gap: 0; }

  .ynav-drawer-nav a {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gray);
    text-decoration: none;
    padding: 14px 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: color 0.25s, padding-left 0.25s;
  }

  .ynav-drawer-nav a:last-child { border-bottom: none; }
  .ynav-drawer-nav a:hover { color: var(--lime); padding-left: 6px; }

  .ynav-drawer-nav a::after {
    content: '›';
    font-size: 18px;
    color: rgba(255,255,255,0.15);
    transition: color 0.25s, transform 0.25s;
  }

  .ynav-drawer-nav a:hover::after { color: var(--lime); transform: translateX(3px); }

  .ynav-drawer-divider { height: 1px; background: rgba(255,107,0,0.08); margin: 16px 0; }

  .ynav-drawer-actions { display: flex; flex-direction: column; gap: 10px; }

  .ynav-drawer-actions .ynav-btn {
    width: 100%;
    justify-content: center;
    padding: 13px 20px;
    font-size: 12px;
  }

  /* ═══════════════════════════════════════
     ✅ CHATBOT BUBBLE
  ═══════════════════════════════════════ */
  .chat-bubble {
    position: fixed;
    bottom: 28px;
    right: 28px;
    z-index: 99999;
  }

  .chat-bubble-btn {
    width: 58px;
    height: 58px;
    border-radius: 50%;
    background: var(--lime);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 24px rgba(255, 107, 0, 0.35);
    transition: transform 0.3s, box-shadow 0.3s;
    position: relative;
  }

  .chat-bubble-btn:hover {
    transform: scale(1.1);
    box-shadow: 0 6px 32px rgba(255, 107, 0, 0.5);
  }

  .chat-bubble-btn svg { width: 26px; height: 26px; fill: var(--dark); }

  /* Pulse ring */
  .chat-bubble-btn::before {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 2px solid rgba(255, 107, 0, 0.4);
    animation: chatPulse 2s ease-in-out infinite;
  }

  @keyframes chatPulse {
    0%, 100% { transform: scale(1); opacity: 0.6; }
    50%       { transform: scale(1.15); opacity: 0; }
  }

  /* Notification dot */
  .chat-notif {
    position: absolute;
    top: 2px; right: 2px;
    width: 12px; height: 12px;
    background: #fff;
    border-radius: 50%;
    border: 2px solid var(--lime);
  }

  /* ✅ Chat window */
  .chat-window {
    position: fixed;
    bottom: 100px;
    right: 28px;
    width: 360px;
    max-height: 520px;
    background: var(--card);
    border: 1px solid rgba(255, 107, 0, 0.15);
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    z-index: 99998;
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
    overflow: hidden;
    transform: scale(0.85) translateY(20px);
    opacity: 0;
    pointer-events: none;
    transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1), opacity 0.3s ease;
    transform-origin: bottom right;
  }

  .chat-window.open {
    transform: scale(1) translateY(0);
    opacity: 1;
    pointer-events: all;
  }

  /* Chat header */
  .chat-header {
    padding: 16px 20px;
    background: linear-gradient(135deg, rgba(255,107,0,0.15), rgba(255,107,0,0.05));
    border-bottom: 1px solid rgba(255,107,0,0.1);
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .chat-avatar {
    width: 38px; height: 38px;
    border-radius: 50%;
    background: var(--lime);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
  }

  .chat-header-info { flex: 1; }

  .chat-header-name {
    font-weight: 700;
    font-size: 14px;
    color: var(--white);
  }

  .chat-header-status {
    font-size: 11px;
    color: #4cde8a;
    display: flex;
    align-items: center;
    gap: 5px;
    margin-top: 2px;
  }

  .chat-header-status::before {
    content: '';
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #4cde8a;
  }

  .chat-close {
    background: none;
    border: none;
    color: var(--gray);
    cursor: pointer;
    font-size: 20px;
    line-height: 1;
    padding: 4px;
    transition: color 0.2s;
  }

  .chat-close:hover { color: var(--white); }

  /* Chat messages */
  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    scrollbar-width: thin;
    scrollbar-color: rgba(255,107,0,0.2) transparent;
  }

  .chat-messages::-webkit-scrollbar { width: 4px; }
  .chat-messages::-webkit-scrollbar-thumb { background: rgba(255,107,0,0.2); border-radius: 4px; }

  .chat-msg {
    display: flex;
    flex-direction: column;
    max-width: 82%;
  }

  .chat-msg.bot  { align-self: flex-start; }
  .chat-msg.user { align-self: flex-end; }

  .chat-bubble-msg {
    padding: 10px 14px;
    border-radius: 12px;
    font-size: 13px;
    line-height: 1.5;
  }

  .chat-msg.bot .chat-bubble-msg {
    background: rgba(255,255,255,0.06);
    color: var(--white);
    border-bottom-left-radius: 4px;
  }

  .chat-msg.user .chat-bubble-msg {
    background: var(--lime);
    color: var(--dark);
    font-weight: 600;
    border-bottom-right-radius: 4px;
  }

  .chat-time {
    font-size: 10px;
    color: var(--gray);
    margin-top: 4px;
    padding: 0 4px;
  }

  .chat-msg.user .chat-time { text-align: right; }

  /* Typing indicator */
  .chat-typing {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 10px 14px;
    background: rgba(255,255,255,0.06);
    border-radius: 12px;
    border-bottom-left-radius: 4px;
    width: fit-content;
  }

  .chat-typing span {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--gray);
    animation: typingDot 1.2s ease-in-out infinite;
  }

  .chat-typing span:nth-child(2) { animation-delay: 0.2s; }
  .chat-typing span:nth-child(3) { animation-delay: 0.4s; }

  @keyframes typingDot {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
    30%            { transform: translateY(-5px); opacity: 1; }
  }

  /* Quick replies */
  .chat-quick {
    padding: 0 16px 12px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .quick-btn {
    font-size: 11px;
    font-weight: 600;
    padding: 6px 12px;
    border-radius: 40px;
    border: 1px solid rgba(255,107,0,0.3);
    background: transparent;
    color: var(--lime);
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    white-space: nowrap;
  }

  .quick-btn:hover { background: var(--lime); color: var(--dark); }

  /* Chat input */
  .chat-input-wrap {
    padding: 12px 16px;
    border-top: 1px solid rgba(255,107,0,0.08);
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .chat-input {
    flex: 1;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,107,0,0.15);
    border-radius: 40px;
    padding: 10px 16px;
    color: var(--white);
    font-size: 13px;
    outline: none;
    transition: border-color 0.3s;
    font-family: 'Satoshi', sans-serif;
  }

  .chat-input::placeholder { color: var(--gray); }
  .chat-input:focus { border-color: rgba(255,107,0,0.4); }

  .chat-send {
    width: 38px; height: 38px;
    border-radius: 50%;
    background: var(--lime);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform 0.2s, opacity 0.2s;
  }

  .chat-send:hover { transform: scale(1.1); }
  .chat-send:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

  .chat-send svg { width: 16px; height: 16px; fill: var(--dark); }

  /* ═══════════════════════════════════════
     RESPONSIVE
  ═══════════════════════════════════════ */
  @media (max-width: 1100px) {
    .ynav-wrap { padding: 0 32px; }
    .ynav-menu { gap: 24px; }
  }

  @media (max-width: 900px) {
    .ynav-menu    { display: none; }
    .ynav-actions { display: none; }
    .ynav-hamburger { display: flex; }
  }

  @media (max-width: 640px) {
    .ynav-wrap { padding: 0 20px; }
    .ynav-brand img { height: 42px; }
    .ynav-brand-text { font-size: 18px; }
    .chat-window { width: calc(100vw - 32px); right: 16px; }
    .chat-bubble { right: 16px; bottom: 16px; }
  }

  @media (max-width: 380px) {
    .ynav-wrap { padding: 0 16px; }
    .ynav-brand img { height: 36px; }
    .ynav-brand-text { font-size: 16px; letter-spacing: 1px; }
  }
</style>

<!-- ═══════════════════════════════════════
     NAVBAR
═══════════════════════════════════════ -->
<nav class="ynav-wrap" id="ynav">

  <a class="ynav-brand" href="/">
    <img src="/images/logo.png" alt="CreativeForge">
    <span class="ynav-brand-text">Creative <span>Forge</span></span>
  </a>

  <ul class="ynav-menu">
    <li><a href="/">Home</a></li>
    <li><a href="/about">About</a></li>
    <li><a href="/services">Services</a></li>
    <li><a href="/portfolio">Portfolio</a></li>
    <li><a href="/review">Reviews</a></li>
    <li><a href="/contact">Contact</a></li>
    <% if (user && user.role === 'admin') { %>
      <li><a href="/admin/contacts">⚙ Contacts</a></li>
    <% } %>
  </ul>

  <div class="ynav-actions">
    <% if (user) { %>
      <!-- ✅ My Bookings link -->
      <a href="/booking/my-bookings" class="ynav-btn ynav-btn--bookings">🧾 My Bookings</a>
      <a href="/contact" class="ynav-btn ynav-btn--primary">Start a Project</a>
      <a href="/logout" class="ynav-btn ynav-btn--logout">Log Out</a>
    <% } else { %>
      <a href="/signin" class="ynav-btn ynav-btn--ghost">Sign In</a>
      <a href="/signup" class="ynav-btn ynav-btn--primary">Sign Up</a>
    <% } %>
  </div>

  <button class="ynav-hamburger" id="ynav-hamburger" aria-label="Toggle menu" aria-expanded="false">
    <span></span><span></span><span></span>
  </button>

</nav>

<!-- Mobile drawer -->
<div class="ynav-drawer" id="ynav-drawer" aria-hidden="true">
  <div class="ynav-drawer-nav">
    <a href="/">Home</a>
    <a href="/about">About</a>
    <a href="/services">Services</a>
    <a href="/portfolio">Portfolio</a>
    <a href="/review">Reviews</a>
    <a href="/contact">Contact</a>
    <% if (user && user.role === 'admin') { %>
      <a href="/admin/contacts">⚙ Contacts</a>
    <% } %>
    <% if (user) { %>
      <a href="/booking/my-bookings">🧾 My Bookings</a>
    <% } %>
  </div>

  <div class="ynav-drawer-divider"></div>

  <div class="ynav-drawer-actions">
    <% if (user) { %>
      <a href="/contact" class="ynav-btn ynav-btn--primary">Start a Project</a>
      <a href="/logout" class="ynav-btn ynav-btn--logout">Log Out</a>
    <% } else { %>
      <a href="/signin" class="ynav-btn ynav-btn--ghost">Sign In</a>
      <a href="/signup" class="ynav-btn ynav-btn--primary">Sign Up</a>
    <% } %>
  </div>
</div>

<!-- ═══════════════════════════════════════
     ✅ CHATBOT BUBBLE + WINDOW
═══════════════════════════════════════ -->

<!-- Chat window -->
<div class="chat-window" id="chatWindow">

  <!-- Header -->
  <div class="chat-header">
    <div class="chat-avatar">🤖</div>
    <div class="chat-header-info">
      <div class="chat-header-name">CreativeForge AI</div>
      <div class="chat-header-status">Online</div>
    </div>
    <button class="chat-close" id="chatClose" aria-label="Close chat">✕</button>
  </div>

  <!-- Messages -->
  <div class="chat-messages" id="chatMessages">
    <div class="chat-msg bot">
      <div class="chat-bubble-msg">
        👋 Hi! I'm your CreativeForge assistant. How can I help you today?
      </div>
      <div class="chat-time">Just now</div>
    </div>
  </div>

  <!-- Quick replies -->
  <div class="chat-quick" id="chatQuick">
    <button class="quick-btn" onclick="sendQuick('What services do you offer?')">Our Services</button>
    <button class="quick-btn" onclick="sendQuick('How can I book a service?')">How to Book</button>
    <button class="quick-btn" onclick="sendQuick('What are your prices?')">Pricing</button>
    <button class="quick-btn" onclick="sendQuick('How can I contact you?')">Contact Us</button>
  </div>

  <!-- Input -->
  <div class="chat-input-wrap">
    <input
      type="text"
      class="chat-input"
      id="chatInput"
      placeholder="Type your message..."
      maxlength="300"
      autocomplete="off">
    <button class="chat-send" id="chatSend" aria-label="Send">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M2 21l21-9L2 3v7l15 2-15 2v7z"/>
      </svg>
    </button>
  </div>

</div>

<!-- Bubble button -->
<div class="chat-bubble">
  <button class="chat-bubble-btn" id="chatToggle" aria-label="Open chat">
    <!-- Chat icon -->
    <svg id="chatIconOpen" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path d="M20 2H4a2 2 0 00-2 2v18l4-4h14a2 2 0 002-2V4a2 2 0 00-2-2z"/>
    </svg>
    <!-- Close icon (hidden by default) -->
    <svg id="chatIconClose" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"
      style="display:none;">
      <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
    </svg>
    <span class="chat-notif" id="chatNotif"></span>
  </button>
</div>

<!-- ═══════════════════════════════════════
     SCRIPTS
═══════════════════════════════════════ -->
<script>
(function () {
  /* ── Navbar scroll + active link ── */
  var ynav      = document.getElementById('ynav');
  var hamburger = document.getElementById('ynav-hamburger');
  var drawer    = document.getElementById('ynav-drawer');

  window.addEventListener('scroll', function () {
    ynav.classList.toggle('scrolled', window.scrollY > 10);
  }, { passive: true });

  function openDrawer() {
    drawer.classList.add('open');
    hamburger.classList.add('open');
    hamburger.setAttribute('aria-expanded', 'true');
    drawer.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeDrawer() {
    drawer.classList.remove('open');
    hamburger.classList.remove('open');
    hamburger.setAttribute('aria-expanded', 'false');
    drawer.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  hamburger.addEventListener('click', function () {
    drawer.classList.contains('open') ? closeDrawer() : openDrawer();
  });

  drawer.querySelectorAll('a').forEach(function (a) {
    a.addEventListener('click', closeDrawer);
  });

  document.addEventListener('click', function (e) {
    if (drawer.classList.contains('open') &&
      !drawer.contains(e.target) &&
      !hamburger.contains(e.target)) {
      closeDrawer();
    }
  });

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeDrawer();
  });

  document.querySelectorAll('.ynav-menu a, .ynav-drawer-nav a').forEach(function (link) {
    if (link.getAttribute('href') === window.location.pathname) {
      link.classList.add('active');
    }
  });

  /* ── Chatbot ── */
  var chatWindow  = document.getElementById('chatWindow');
  var chatToggle  = document.getElementById('chatToggle');
  var chatClose   = document.getElementById('chatClose');
  var chatMessages = document.getElementById('chatMessages');
  var chatInput   = document.getElementById('chatInput');
  var chatSend    = document.getElementById('chatSend');
  var chatQuick   = document.getElementById('chatQuick');
  var chatNotif   = document.getElementById('chatNotif');
  var iconOpen    = document.getElementById('chatIconOpen');
  var iconClose   = document.getElementById('chatIconClose');

  var isOpen = false;

  function toggleChat() {
    isOpen = !isOpen;
    chatWindow.classList.toggle('open', isOpen);
    iconOpen.style.display  = isOpen ? 'none'  : 'block';
    iconClose.style.display = isOpen ? 'block' : 'none';
    // Hide notif dot once opened
    if (isOpen) {
      chatNotif.style.display = 'none';
      chatInput.focus();
    }
  }

  chatToggle.addEventListener('click', toggleChat);
  chatClose.addEventListener('click',  toggleChat);

  // Close on outside click
  document.addEventListener('click', function (e) {
    if (isOpen &&
      !chatWindow.contains(e.target) &&
      !chatToggle.contains(e.target)) {
      toggleChat();
    }
  });

  /* ── Time helper ── */
  function getTime() {
    return new Date().toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' });
  }

  /* ── Append message ── */
  function appendMsg(text, role) {
    var div = document.createElement('div');
    div.className = 'chat-msg ' + role;
    div.innerHTML =
      '<div class="chat-bubble-msg">' + text + '</div>' +
      '<div class="chat-time">' + getTime() + '</div>';
    chatMessages.appendChild(div);
    chatMessages.scrollTop = chatMessages.scrollHeight;
  }

  /* ── Typing indicator ── */
  function showTyping() {
    var t = document.createElement('div');
    t.className = 'chat-msg bot';
    t.id = 'typingIndicator';
    t.innerHTML =
      '<div class="chat-typing">' +
        '<span></span><span></span><span></span>' +
      '</div>';
    chatMessages.appendChild(t);
    chatMessages.scrollTop = chatMessages.scrollHeight;
  }

  function hideTyping() {
    var t = document.getElementById('typingIndicator');
    if (t) t.remove();
  }

  /* ── Send message to /chat route ── */
  async function sendMessage(text) {
    if (!text.trim()) return;

    // Hide quick replies after first message
    chatQuick.style.display = 'none';

    appendMsg(text, 'user');
    chatInput.value = '';
    chatSend.disabled = true;

    showTyping();

    try {
      const res = await fetch('/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: text })
      });

      const data = await res.json();
      hideTyping();

      if (data.reply) {
        appendMsg(data.reply, 'bot');
      } else {
        appendMsg('Sorry, I couldn\'t get a response. Please try again.', 'bot');
      }

    } catch (err) {
      hideTyping();
      appendMsg('Something went wrong. Please try again later.', 'bot');
    }

    chatSend.disabled = false;
    chatInput.focus();
  }

  /* ── Quick reply buttons ── */
  window.sendQuick = function(text) {
    if (!isOpen) toggleChat();
    sendMessage(text);
  };

  /* ── Send on button click ── */
  chatSend.addEventListener('click', function () {
    sendMessage(chatInput.value);
  });

  /* ── Send on Enter key ── */
  chatInput.addEventListener('keydown', function (e) {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendMessage(chatInput.value);
    }
  });

  // Show notif dot after 3s to draw attention
  setTimeout(function () {
    if (!isOpen) chatNotif.style.display = 'block';
  }, 3000);

})();
</script>

<%- include('scripts') %>