<%- include('head') %>
  <style>
    :root {
      --lime: #C8F135;
      --dark: #0C0F14;
      --dark3: #1a2030;
      --white: #FFFFFF;
      --gray: #8a9bb0;
      --card: #141b26;
      --nav-h: 64px;
    }

    /* ═══════════════════════════════════════
       NAVBAR
    ═══════════════════════════════════════ */
    .ynav-wrap {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      height: var(--nav-h);
      z-index: 99999;
      padding: 0 60px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: rgba(20, 27, 36, 0.85); /* ✅ #141B24 */
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(200, 241, 53, 0.08);
      transition: background 0.4s, border-color 0.4s;
    }

    .ynav-wrap.scrolled {
      background: rgba(20, 27, 36, 0.97); /* ✅ #141B24 */
      border-color: rgba(200, 241, 53, 0.14);
    }

    /* ── Brand / Logo ── */
    .ynav-brand {
      display: flex;
      align-items: center;
      gap: 12px;
      text-decoration: none;
      flex-shrink: 0;
      transition: opacity 0.2s;
      z-index: 1;
    }

    .ynav-brand:hover {
      opacity: 0.85;
    }

    .ynav-brand img {
      height: 52px;
      width: auto;
      display: block;
      object-fit: contain;
    }

    .ynav-brand-text {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 22px;
      letter-spacing: 2px;
      color: var(--white);
      display: block;
    }

    .ynav-brand-text span {
      color: var(--lime);
    }

    /* ── Center menu (desktop) ── */
    .ynav-menu {
      display: flex;
      gap: 32px;
      list-style: none;
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
    }

    .ynav-menu a {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: var(--gray);
      text-decoration: none;
      position: relative;
      transition: color 0.3s;
      white-space: nowrap;
    }

    .ynav-menu a::after {
      content: '';
      position: absolute;
      bottom: -4px;
      left: 0;
      width: 0;
      height: 1px;
      background: var(--lime);
      transition: width 0.3s ease;
    }

    .ynav-menu a:hover,
    .ynav-menu a.active {
      color: var(--white);
    }

    .ynav-menu a:hover::after,
    .ynav-menu a.active::after {
      width: 100%;
    }

    /* ── Right actions (desktop) ── */
    .ynav-actions {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-shrink: 0;
      z-index: 1;
    }

    .ynav-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-weight: 700;
      font-size: 11px;
      letter-spacing: 2px;
      text-transform: uppercase;
      padding: 9px 20px;
      border: none;
      cursor: pointer;
      text-decoration: none;
      border-radius: 40px;
      transition: background 0.3s, color 0.3s, transform 0.2s, border-color 0.3s;
      white-space: nowrap;
    }

    .ynav-btn--primary {
      background: var(--lime);
      color: var(--dark);
    }

    .ynav-btn--primary:hover {
      background: var(--white);
      color: var(--dark);
      transform: translateY(-1px);
    }

    .ynav-btn--ghost {
      background: transparent;
      color: var(--lime);
      border: 1px solid rgba(200, 241, 53, 0.35);
    }

    .ynav-btn--ghost:hover {
      background: var(--lime);
      color: var(--dark);
      transform: translateY(-1px);
    }

    .ynav-btn--logout {
      background: transparent;
      color: var(--gray);
      border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .ynav-btn--logout:hover {
      background: #ff4d4d;
      color: var(--white);
      border-color: #ff4d4d;
      transform: translateY(-1px);
    }

    /* ═══════════════════════════════════════
       ANIMATED HAMBURGER
    ═══════════════════════════════════════ */
    .ynav-hamburger {
      display: none;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      width: 40px;
      height: 40px;
      cursor: pointer;
      background: none;
      border: none;
      padding: 4px;
      border-radius: 8px;
      transition: background 0.2s;
      z-index: 1;
      -webkit-tap-highlight-color: transparent;
    }

    .ynav-hamburger span {
      display: block;
      width: 22px;
      height: 2px;
      background: var(--white);
      border-radius: 2px;
      transition: transform 0.3s ease, opacity 0.3s ease, width 0.3s ease;
      transform-origin: center;
    }

    .ynav-hamburger.open span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }

    .ynav-hamburger.open span:nth-child(2) {
      opacity: 0;
      transform: scaleX(0);
    }

    .ynav-hamburger.open span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }

    /* ═══════════════════════════════════════
       MOBILE DRAWER
    ═══════════════════════════════════════ */
    .ynav-drawer {
      position: fixed;
      top: var(--nav-h);
      left: 0;
      right: 0;
      background: rgba(20, 27, 36, 0.98); /* ✅ #141B24 */
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border-bottom: 1px solid rgba(200, 241, 53, 0.1);
      padding: 0 24px;
      z-index: 99998;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1),
        padding 0.3s ease;
    }

    .ynav-drawer.open {
      max-height: 600px;
      padding: 16px 24px 28px;
    }

    .ynav-drawer-nav {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .ynav-drawer-nav a {
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--gray);
      text-decoration: none;
      padding: 14px 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      display: flex;
      align-items: center;
      justify-content: space-between;
      transition: color 0.25s, padding-left 0.25s;
    }

    .ynav-drawer-nav a:last-child {
      border-bottom: none;
    }

    .ynav-drawer-nav a:hover {
      color: var(--lime);
      padding-left: 6px;
    }

    .ynav-drawer-nav a::after {
      content: '›';
      font-size: 18px;
      color: rgba(255, 255, 255, 0.15);
      transition: color 0.25s, transform 0.25s;
    }

    .ynav-drawer-nav a:hover::after {
      color: var(--lime);
      transform: translateX(3px);
    }

    .ynav-drawer-divider {
      height: 1px;
      background: rgba(200, 241, 53, 0.08);
      margin: 16px 0;
    }

    .ynav-drawer-actions {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .ynav-drawer-actions .ynav-btn {
      width: 100%;
      justify-content: center;
      padding: 13px 20px;
      font-size: 12px;
    }

    /* ═══════════════════════════════════════
       RESPONSIVE
    ═══════════════════════════════════════ */
    @media (max-width: 1100px) {
      .ynav-wrap {
        padding: 0 32px;
      }

      .ynav-menu {
        gap: 24px;
      }
    }

    @media (max-width: 900px) {
      .ynav-menu {
        display: none;
      }

      .ynav-actions {
        display: none;
      }

      .ynav-hamburger {
        display: flex;
      }
    }

    @media (max-width: 640px) {
      .ynav-wrap {
        padding: 0 20px;
      }

      .ynav-brand img {
        height: 42px;
      }

      .ynav-brand-text {
        font-size: 18px;
      }
    }

    @media (max-width: 380px) {
      .ynav-wrap {
        padding: 0 16px;
      }

      .ynav-brand img {
        height: 36px;
      }

      .ynav-brand-text {
        font-size: 16px;
        letter-spacing: 1px;
      }
    }
  </style>

  <nav class="ynav-wrap" id="ynav">

    <!-- Logo + Text -->
    <a class="ynav-brand" href="/">
      <img src="/images/logo.png" alt="Ya.Showtime Studio"> <!-- ✅ fixed filename -->
      <span class="ynav-brand-text">Ya.<span>Showtimestudio</span></span>
    </a>

    <!-- Center links (desktop) -->
    <ul class="ynav-menu">
      <li><a href="/">Home</a></li>
      <li><a href="/about">About</a></li>
      <li><a href="/services">Services</a></li>
      <li><a href="/portfolio">Portfolio</a></li>
      <li><a href="/review">Reviews</a></li>
      <li><a href="/contact">Contact</a></li>
      <% if (user && user.role==='admin') { %>
        <li><a href="/admin/contacts">⚙ Contacts</a></li>
      <% } %>
    </ul>

    <!-- Right actions (desktop) -->
    <div class="ynav-actions">
      <% if (user) { %>
        <a href="/contact" class="ynav-btn ynav-btn--primary">Start a Project</a>
        <a href="/logout" class="ynav-btn ynav-btn--logout">Log Out</a>
      <% } else { %>
        <a href="/signin" class="ynav-btn ynav-btn--ghost">Sign In</a>
        <a href="/signup" class="ynav-btn ynav-btn--primary">Sign Up</a>
      <% } %>
    </div>

    <!-- Animated hamburger -->
    <button class="ynav-hamburger" id="ynav-hamburger" aria-label="Toggle menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>

  </nav>

  <!-- Mobile drawer -->
  <div class="ynav-drawer" id="ynav-drawer" aria-hidden="true">

    <div class="ynav-drawer-nav">
      <a href="/">Home</a>
      <a href="/about">About</a>
      <a href="/services">Services</a>
      <a href="/portfolio">Portfolio</a>
      <a href="/review">Reviews</a>
      <a href="/contact">Contact</a>
      <% if (user && user.role==='admin') { %>
        <a href="/admin/contacts">⚙ Contacts</a>
      <% } %>
    </div>

    <div class="ynav-drawer-divider"></div>

    <div class="ynav-drawer-actions">
      <% if (user) { %>
        <a href="/contact" class="ynav-btn ynav-btn--primary">Start a Project</a>
        <a href="/logout" class="ynav-btn ynav-btn--logout">Log Out</a>
      <% } else { %>
        <a href="/signin" class="ynav-btn ynav-btn--ghost">Sign In</a>
        <a href="/signup" class="ynav-btn ynav-btn--primary">Sign Up</a>
      <% } %>
    </div>

  </div>

  <script>
    (function () {
      var ynav      = document.getElementById('ynav');
      var hamburger = document.getElementById('ynav-hamburger');
      var drawer    = document.getElementById('ynav-drawer');

      window.addEventListener('scroll', function () {
        ynav.classList.toggle('scrolled', window.scrollY > 10);
      }, { passive: true });

      function openDrawer() {
        drawer.classList.add('open');
        hamburger.classList.add('open');
        hamburger.setAttribute('aria-expanded', 'true');
        drawer.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      }

      function closeDrawer() {
        drawer.classList.remove('open');
        hamburger.classList.remove('open');
        hamburger.setAttribute('aria-expanded', 'false');
        drawer.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }

      hamburger.addEventListener('click', function () {
        drawer.classList.contains('open') ? closeDrawer() : openDrawer();
      });

      drawer.querySelectorAll('a').forEach(function (a) {
        a.addEventListener('click', closeDrawer);
      });

      document.addEventListener('click', function (e) {
        if (drawer.classList.contains('open') &&
          !drawer.contains(e.target) &&
          !hamburger.contains(e.target)) {
          closeDrawer();
        }
      });

      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeDrawer();
      });

      document.querySelectorAll('.ynav-menu a, .ynav-drawer-nav a').forEach(function (link) {
        if (link.getAttribute('href') === window.location.pathname) {
          link.classList.add('active');
        }
      });
    })();
  </script>

<%- include('scripts') %>