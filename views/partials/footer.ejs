<style>
  :root {
    --lime: #FF6B00;
    --dark: #0C0F14;
    --dark2: #131820;
    --white: #FFFFFF;
    --gray: #8a9bb0;
  }

  /* ========================= FOOTER ========================= */
  footer {
    background: var(--dark2);
    padding: 60px;
    border-top: 1px solid rgba(255, 107, 0, 0.08);
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 60px;
  }

  .footer-brand .logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 36px;
    letter-spacing: 2px;
    color: var(--white);
    margin-bottom: 16px;
  }

  .footer-brand .logo span {
    color: var(--lime);
  }

  .footer-brand p {
    font-size: 13px;
    line-height: 1.7;
    color: var(--gray);
  }

  .footer-social {
    display: flex;
    gap: 12px;
    margin-top: 24px;
  }

  /* ---- Social buttons with brand colors on hover ---- */
  .social-btn {
    width: 38px;
    height: 38px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: var(--gray);
    transition: border-color 0.3s, background 0.3s, color 0.3s, transform 0.2s;
    flex-shrink: 0;
  }

  .social-btn svg {
    width: 18px;
    height: 18px;
    fill: currentColor;
    display: block;
  }

  .social-btn:hover {
    transform: translateY(-2px);
  }

  /* Brand-specific hover colours */
  .social-btn.instagram:hover {
    background: #E1306C;
    border-color: #E1306C;
    color: #fff;
  }

  .social-btn.youtube:hover {
    background: #FF0000;
    border-color: #FF0000;
    color: #fff;
  }

  .social-btn.facebook:hover {
    background: #1877F2;
    border-color: #1877F2;
    color: #fff;
  }

  .social-btn.gmail:hover {
    background: #EA4335;
    border-color: #EA4335;
    color: #fff;
  }

  /* ---- Columns ---- */
  .footer-col h4 {
    font-family: 'Syne', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--lime);
    margin-bottom: 20px;
  }

  .footer-col ul {
    list-style: none;
  }

  .footer-col ul li {
    margin-bottom: 12px;
    font-size: 13px;
    color: var(--gray);
    transition: color 0.3s;
    cursor: default;
  }

  .footer-col ul li:hover {
    color: var(--white);
  }

  .footer-col ul li a {
    color: inherit;
    text-decoration: none;
    cursor: pointer;
  }

  /* ========================= FOOTER BOTTOM ========================= */
  .footer-bottom {
    background: var(--dark2);
    padding: 20px 60px;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 12px;
    color: var(--gray);
  }

  /* ========================= RESPONSIVE ========================= */
  @media (max-width: 1024px) {
    footer {
      grid-template-columns: 1fr 1fr;
      gap: 40px;
      padding: 40px 32px;
    }

    .footer-bottom {
      padding: 20px 32px;
      flex-direction: column;
      gap: 12px;
      text-align: center;
    }
  }

  @media (max-width: 640px) {
    footer {
      grid-template-columns: 1fr;
      padding: 36px 20px;
    }

    .footer-bottom {
      padding: 16px 20px;
    }
  }
</style>

