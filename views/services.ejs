<%- include('partials/head') %>
<%- include('partials/navbar') %>

<style>
  :root {
    --lime: #FF6B00;
    --dark:  #0C0F14;
    --dark2: #131820;
    --dark3: #1a2030;
    --white: #FFFFFF;
    --gray:  #8a9bb0;
    --card:  #141b26;
    --nav-h: 72px;
  }

  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--dark);
    color: var(--white);
    overflow-x: hidden;
  }

  /* ── Shared ── */
  .section-label {
    font-family: 'Syne', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--lime);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
  }

  .section-label::before,
  .section-label::after {
    content: '';
    width: 28px;
    height: 1px;
    background: var(--lime);
    flex-shrink: 0;
  }

  .section-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(56px, 8vw, 110px);
    line-height: 1;
    letter-spacing: -1px;
  }

  .section-title .accent { color: var(--lime); }

  /* ── Buttons ── */
  .btn-primary {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: 'Syne', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    background: var(--lime);
    color: var(--dark);
    border: none;
    padding: 15px 36px;
    border-radius: 40px;
    cursor: pointer;
    overflow: hidden;
    text-decoration: none;
    transition: transform 0.2s;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .btn-primary::before {
    content: '';
    position: absolute;
    inset: 0;
    background: #fff;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s cubic-bezier(.77,0,.18,1);
    border-radius: 40px;
  }

  .btn-primary:hover::before { transform: scaleX(1); }
  .btn-primary:hover { transform: translateY(-2px); }
  .btn-primary > * { position: relative; z-index: 1; }

  .btn-dark {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: 'Syne', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    background: #111;
    color: var(--white);
    border: 1px solid rgba(255,255,255,0.18);
    padding: 16px 36px;
    border-radius: 40px;
    cursor: pointer;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: border-color 0.3s, color 0.3s, transform 0.2s;
  }

  .btn-dark:hover {
    border-color: var(--lime);
    color: var(--lime);
    transform: translateY(-2px);
  }

  /* ── Fade-in ── */
  .fade-in {
    opacity: 0;
    transform: translateY(22px);
    animation: fadeInUp 0.9s ease forwards;
  }

  .d1 { animation-delay: 0.15s; }
  .d2 { animation-delay: 0.30s; }
  .d3 { animation-delay: 0.45s; }

  @keyframes fadeInUp {
    to { opacity: 1; transform: translateY(0); }
  }

  /* ═══════════════════════════════════════
     HERO
  ═══════════════════════════════════════ */
  .services-hero {
    padding: calc(var(--nav-h) + 60px) 60px 40px;
    text-align: center;
  }

  .hero-sub {
    color: var(--gray);
    font-size: 16px;
    margin-top: 20px;
    max-width: 600px;
    font-weight: 300;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.7;
  }

  /* ── Tab nav ── */
  .service-tabs {
    display: flex;
    gap: 0;
    justify-content: center;
    margin-top: 48px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .service-tabs::-webkit-scrollbar { display: none; }

  .tab-btn {
    font-family: 'Syne', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gray);
    background: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    padding: 14px 28px;
    cursor: pointer;
    white-space: nowrap;
    transition: color 0.3s, border-color 0.3s;
    margin-bottom: -1px;
  }

  .tab-btn:hover { color: var(--white); }
  .tab-btn.active { color: var(--lime); border-bottom-color: var(--lime); }

  /* ═══════════════════════════════════════
     SERVICE BLOCKS
  ═══════════════════════════════════════ */
  .service-block {
    padding: 80px 60px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
    border-top: 1px solid rgba(255,255,255,0.05);
    transition: background 0.4s;
  }

  .service-block:hover { background: rgba(200,241,53,0.015); }

  /* Reverse layout for even blocks */
  .service-block.reverse { direction: rtl; }
  .service-block.reverse > * { direction: ltr; }

  .service-block-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(80px, 10vw, 130px);
    color: rgba(200,241,53,0.05);
    line-height: 1;
    margin-bottom: -20px;
  }

  .service-block-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(40px, 5vw, 72px);
    line-height: 1;
    letter-spacing: -1px;
  }

  .service-block-title .accent { color: var(--lime); }

  .service-block-desc {
    font-size: 15px;
    line-height: 1.8;
    color: var(--gray);
    margin: 20px 0;
    font-weight: 300;
  }

  /* ── Services list ── */
  .services-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    margin-top: 32px;
  }

  .services-list-item {
    padding: 13px 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    font-size: 13px;
    color: var(--gray);
    display: flex;
    align-items: center;
    gap: 10px;
    transition: color 0.3s, padding-left 0.3s;
  }

  .services-list-item:hover {
    color: var(--white);
    padding-left: 4px;
  }

  .services-list-item::before {
    content: '';
    width: 6px;
    height: 6px;
    background: var(--lime);
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* ── Visual panel ── */
  .service-block-visual {
    background: var(--card);
    border: 1px solid rgba(200,241,53,0.1);
    height: 380px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    transition: border-color 0.4s;
  }

  .service-block:hover .service-block-visual {
    border-color: rgba(200,241,53,0.2);
  }

  .service-block-visual-icon {
    font-size: 100px;
    opacity: 0.1;
    position: absolute;
    transition: opacity 0.4s, transform 0.4s;
  }

  .service-block:hover .service-block-visual-icon {
    opacity: 0.18;
    transform: scale(1.1);
  }

  .service-block-visual-content {
    position: relative;
    z-index: 1;
    text-align: center;
  }

  .service-block-visual-content .big-text {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(48px, 7vw, 72px);
    color: var(--lime);
    line-height: 1;
  }

  .service-block-visual-content p {
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gray);
    margin-top: 10px;
  }

  /* ── Block CTA ── */
  .block-cta {
    margin-top: 32px;
  }

  /* ═══════════════════════════════════════
     CTA SECTION
  ═══════════════════════════════════════ */
  .cta-section {
    margin: 0 60px 120px;
    padding: 72px 60px;
    background: linear-gradient(135deg, #141b26, #0c0f14);
    border: 1px solid rgba(200,241,53,0.13);
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-radius: 16px;
    gap: 40px;
    position: relative;
    overflow: hidden;
  }

  .cta-section::before {
    content: '';
    position: absolute;
    top: -80px; right: -80px;
    width: 320px; height: 320px;
    background: radial-gradient(circle, rgba(200,241,53,0.05) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  .cta-section h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(32px, 4vw, 52px);
    line-height: 1.05;
    margin-bottom: 10px;
    position: relative;
    z-index: 1;
  }

  .cta-section p {
    color: var(--gray);
    font-size: 14px;
    position: relative;
    z-index: 1;
  }

  .cta-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  /* ═══════════════════════════════════════
     RESPONSIVE
  ═══════════════════════════════════════ */
  @media (max-width: 1024px) {
    .services-hero { padding: calc(var(--nav-h) + 40px) 32px 32px; }

    .service-block {
      grid-template-columns: 1fr;
      padding: 60px 32px;
      gap: 40px;
      direction: ltr !important;
    }

    .service-block > * { direction: ltr !important; }

    /* Visual goes below content on tablet */
    .service-block-visual { order: 2; }
    .service-block > div:first-child { order: 1; }

    .cta-section { margin: 0 32px 80px; padding: 48px 36px; }
    .cta-actions { justify-content: flex-start; }
  }

  @media (max-width: 768px) {
    .service-block-visual { height: 280px; }

    .service-block-visual-content .big-text { font-size: 52px; }

    .services-list { grid-template-columns: 1fr; }
    .services-list-item { padding: 11px 0; }
  }

  @media (max-width: 640px) {
    .services-hero {
      padding: calc(var(--nav-h) + 24px) 20px 24px;
    }

    .hero-sub { font-size: 14px; }

    .service-tabs { justify-content: flex-start; padding: 0 20px; }
    .tab-btn { padding: 12px 18px; font-size: 10px; }

    .service-block {
      padding: 48px 20px;
      gap: 28px;
    }

    .service-block-num { font-size: 72px; margin-bottom: -12px; }

    .service-block-visual { height: 220px; }
    .service-block-visual-icon { font-size: 70px; }
    .service-block-visual-content .big-text { font-size: 40px; }
    .service-block-visual-content p { font-size: 10px; letter-spacing: 2px; }

    .cta-section {
      margin: 0 20px 60px;
      flex-direction: column;
      align-items: flex-start;
      padding: 36px 24px;
    }

    .cta-actions {
      width: 100%;
      flex-direction: column;
    }

    .cta-actions .btn-primary,
    .cta-actions .btn-dark {
      width: 100%;
      justify-content: center;
    }
  }

  @media (max-width: 380px) {
    .service-block { padding: 40px 16px; }
    .service-block-title { font-size: 36px; }
  }
</style>

