<script>
  /* ── Tab scroll ── */
  function scrollTo(id) {
    const el = document.getElementById(id);
    if (!el) return;
    const offset = parseInt(getComputedStyle(document.documentElement)
      .getPropertyValue('--nav-h')) || 72;
    window.scrollTo({ top: el.offsetTop - offset - 16, behavior: 'smooth' });

    // Update active tab
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    event.currentTarget.classList.add('active');
  }

  /* ── Highlight tab on scroll ── */
  const sections = ['brand','marketing','tech','social'].map(id => document.getElementById(id));
  const tabs     = document.querySelectorAll('.tab-btn');

  window.addEventListener('scroll', function () {
    const navH = 80;
    let current = 0;
    sections.forEach((s, i) => {
      if (s && s.getBoundingClientRect().top <= navH + 40) current = i;
    });
    tabs.forEach(t => t.classList.remove('active'));
    if (tabs[current]) tabs[current].classList.add('active');
  }, { passive: true });
</script>

